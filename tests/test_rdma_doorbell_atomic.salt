// =============================================================================
// Test: Atomic Doorbell — 128-bit [u64; 2] Write Verification
// =============================================================================
// Validates that the atomic doorbell write:
//   1. Writes both control and payload in a single [u64; 2] operation
//   2. The array layout places control at byte 0 and payload at byte 8
//   3. WQE as_array() produces correct [control, payload] ordering
//   4. The array write does not corrupt adjacent memory (16B boundary)
//   5. Multiple atomic doorbell writes overwrite correctly
//
// Exit codes:
//   0 = all passed
//   1 = allocation failure
//   2 = control word incorrect after atomic write
//   3 = payload word incorrect after atomic write
//   4 = opcode extraction failed
//   5 = offset extraction failed
//   6 = adjacent memory corrupted (128-bit boundary violation)
//   7 = second atomic write failed
//   8 = as_array ordering incorrect
// =============================================================================

package main

import std.core.ptr.Ptr

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: u64);

// Doorbell offset (matches rdma_doorbell.salt)
const DOORBELL_OFFSET: u64 = 0x1000;

fn main() -> i32 {
    // =========================================================================
    // Allocate mock NIC BAR (8KB for BAR base + doorbell at +0x1000)
    // =========================================================================
    let bar_size: i64 = 8192;
    let bar_addr: u64 = (malloc(bar_size) as u64);
    if bar_addr == 0 { return 1; }

    // Zero-fill
    let mut i: i64 = 0;
    while i < bar_size {
        *((bar_addr + (i as u64)) as &mut u8) = 0;
        i = i + 1;
    }

    // =========================================================================
    // T1: Atomic [u64; 2] write to mock doorbell
    // =========================================================================
    let tensor_offset: u32 = 42;
    let payload: u64 = 0xDEADBEEFCAFEBABE;

    // Construct WQE control word
    let control: u64 = (1 << 32) | (tensor_offset as u64);

    // Atomic 128-bit write
    let doorbell_addr: u64 = bar_addr + DOORBELL_OFFSET;
    let doorbell: Ptr<[u64; 2]> = doorbell_addr as Ptr<[u64; 2]>;
    doorbell.write([control, payload]);

    // Read back as individual u64s to verify layout
    let read_control: u64 = *((doorbell_addr) as &u64);
    let read_payload: u64 = *((doorbell_addr + 8) as &u64);

    if read_control != control {
        free(bar_addr);
        return 2;
    }

    if read_payload != 0xDEADBEEFCAFEBABE {
        free(bar_addr);
        return 3;
    }

    // Verify opcode extraction
    let opcode: u64 = (read_control >> 32) & 0xFFFFFFFF;
    if opcode != 1 {
        free(bar_addr);
        return 4;
    }

    // Verify offset extraction
    let extracted_offset: u32 = (read_control & 0xFFFFFFFF) as u32;
    if extracted_offset != 42 {
        free(bar_addr);
        return 5;
    }

    // =========================================================================
    // T2: Verify 128-bit boundary — adjacent memory untouched
    // =========================================================================
    // Write a sentinel at doorbell + 16 (should not be clobbered)
    *((doorbell_addr + 16) as &mut u64) = 0x1234567890ABCDEF;

    // Re-do the atomic write
    doorbell.write([control, payload]);

    // Check sentinel
    let sentinel: u64 = *((doorbell_addr + 16) as &u64);
    if sentinel != 0x1234567890ABCDEF {
        free(bar_addr);
        return 6;
    }

    // =========================================================================
    // T3: Second atomic write overwrites correctly
    // =========================================================================
    let control2: u64 = (1 << 32) | 96;
    let payload2: u64 = 0xAAAABBBBCCCCDDDD;

    doorbell.write([control2, payload2]);

    let final_control: u64 = *((doorbell_addr) as &u64);
    let final_payload: u64 = *((doorbell_addr + 8) as &u64);

    if final_payload != 0xAAAABBBBCCCCDDDD {
        free(bar_addr);
        return 7;
    }

    let final_offset: u32 = (final_control & 0xFFFFFFFF) as u32;
    if final_offset != 96 {
        free(bar_addr);
        return 7;
    }

    // =========================================================================
    // T4: WQE as_array — verify ordering [control, payload]
    // =========================================================================
    // Inline the as_array logic
    let wqe_control: u64 = (1 << 32) | 7;
    let wqe_payload: u64 = 0x5555666677778888;
    let arr: [u64; 2] = [wqe_control, wqe_payload];

    // arr[0] should be control, arr[1] should be payload
    if arr[0] != wqe_control {
        free(bar_addr);
        return 8;
    }
    if arr[1] != wqe_payload {
        free(bar_addr);
        return 8;
    }

    free(bar_addr);
    return 0;
}
