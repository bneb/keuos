// =============================================================================
// TEST: NetD SYN Cookie Integration — Red-to-Green TDD
// =============================================================================
// Tests that netd_tcp correctly uses SYN cookies instead of allocating TCBs
// in the SYN path, and only allocates after cookie validation in the ACK path.
// =============================================================================

package main

// Simulated versions of the SYN cookie functions (inlined for test isolation)
// These mirror the exact logic in kernel/net/tcp_syn_cookie.salt

// --- SipHash-2-4 (inlined for test self-containment) ---
fn rotl64(x: u64, n: i32) -> u64 {
    return (x << n) | (x >> (64 - n));
}

struct SipState {
    v0: u64,
    v1: u64,
    v2: u64,
    v3: u64,
}

fn sip_round(s: &mut SipState) {
    s.v0 = s.v0 + s.v1;
    s.v1 = rotl64(s.v1, 13);
    s.v1 = s.v1 ^ s.v0;
    s.v0 = rotl64(s.v0, 32);
    s.v2 = s.v2 + s.v3;
    s.v3 = rotl64(s.v3, 16);
    s.v3 = s.v3 ^ s.v2;
    s.v0 = s.v0 + s.v3;
    s.v3 = rotl64(s.v3, 21);
    s.v3 = s.v3 ^ s.v0;
    s.v2 = s.v2 + s.v1;
    s.v1 = rotl64(s.v1, 17);
    s.v1 = s.v1 ^ s.v2;
    s.v2 = rotl64(s.v2, 32);
}

fn siphash_2_4(k0: u64, k1: u64, m0: u64, m1: u64) -> u64 {
    let mut s = SipState {
        v0: k0 ^ 0x736f6d6570736575,
        v1: k1 ^ 0x646f72616e646f6d,
        v2: k0 ^ 0x6c7967656e657261,
        v3: k1 ^ 0x7465646279746573,
    };
    s.v3 = s.v3 ^ m0;
    sip_round(&mut s); sip_round(&mut s);
    s.v0 = s.v0 ^ m0;
    s.v3 = s.v3 ^ m1;
    sip_round(&mut s); sip_round(&mut s);
    s.v0 = s.v0 ^ m1;
    let len_byte: u64 = 16 << 56;
    s.v3 = s.v3 ^ len_byte;
    sip_round(&mut s); sip_round(&mut s);
    s.v0 = s.v0 ^ len_byte;
    s.v2 = s.v2 ^ 0xFF;
    sip_round(&mut s); sip_round(&mut s);
    sip_round(&mut s); sip_round(&mut s);
    return s.v0 ^ s.v1 ^ s.v2 ^ s.v3;
}

// --- SYN cookie core functions ---
global SECRET_K0: u64 = 0xDEADBEEFCAFEBABE;
global SECRET_K1: u64 = 0x0123456789ABCDEF;
global TICK_CTR: u64 = 0;

fn generate_syn_cookie(src_ip: u32, dst_ip: u32, src_port: u16, dst_port: u16, client_isn: u32) -> u32 {
    let tuple_hi: u64 = ((src_ip as u64) << 32) | (dst_ip as u64);
    let tuple_lo: u64 = ((src_port as u64) << 16) | (dst_port as u64);
    let hash_val = siphash_2_4(SECRET_K0, SECRET_K1, tuple_hi, tuple_lo);
    let t = TICK_CTR >> 6;
    let mss_idx: u32 = 3;
    let cookie: u32 = ((t as u32 & 31) << 27) | ((mss_idx & 7) << 24)
                     | (((hash_val as u32) + client_isn) & 0x00FFFFFF);
    if cookie == 0 { return 1; }
    return cookie;
}

fn validate_syn_cookie(cookie: u32, src_ip: u32, dst_ip: u32, src_port: u16, dst_port: u16, client_isn: u32) -> bool {
    let t_cookie = (cookie >> 27) & 31;
    let t_now = (TICK_CTR >> 6) as u32 & 31;
    let dt = if t_now >= t_cookie { t_now - t_cookie } else { t_cookie - t_now };
    if dt > 2 { return false; }
    let tuple_hi: u64 = ((src_ip as u64) << 32) | (dst_ip as u64);
    let tuple_lo: u64 = ((src_port as u64) << 16) | (dst_port as u64);
    let hash_val = siphash_2_4(SECRET_K0, SECRET_K1, tuple_hi, tuple_lo);
    let expected_hash = ((hash_val as u32) + client_isn) & 0x00FFFFFF;
    return (cookie & 0x00FFFFFF) == expected_hash;
}

// --- Simulated TCB Pool (mirrors netd_tcp.salt) ---
pub const TCP_CLOSED: u8       = 0;
pub const TCP_SYN_RECEIVED: u8 = 3;
pub const TCP_ESTABLISHED: u8  = 4;
pub const MAX_TCP_SOCKETS: u64 = 64;

pub struct TcpConnection {
    pub state: u8,
    pub local_port: u16,
    pub remote_port: u16,
    pub remote_ip: u32,
    pub seq_snd: u32,
    pub seq_rcv: u32,
}

global POOL: [TcpConnection; 64] = [TcpConnection {
    state: 0, local_port: 0, remote_port: 0, remote_ip: 0,
    seq_snd: 0, seq_rcv: 0,
}; 64];

fn pool_alloc() -> u64 {
    let mut i: u64 = 0;
    while i < MAX_TCP_SOCKETS {
        if POOL[i].state == TCP_CLOSED {
            return i;
        }
        i = i + 1;
    }
    return 0xFFFFFFFF;
}

fn pool_active_count() -> u64 {
    let mut count: u64 = 0;
    let mut i: u64 = 0;
    while i < MAX_TCP_SOCKETS {
        if POOL[i].state != TCP_CLOSED { count = count + 1; }
        i = i + 1;
    }
    return count;
}

fn pool_clear() {
    let mut i: u64 = 0;
    while i < MAX_TCP_SOCKETS {
        POOL[i].state = TCP_CLOSED;
        POOL[i].local_port = 0;
        POOL[i].remote_port = 0;
        POOL[i].remote_ip = 0;
        POOL[i].seq_snd = 0;
        POOL[i].seq_rcv = 0;
        i = i + 1;
    }
}

// =============================================================================
// handle_syn — Stateless SYN processing (THE INTEGRATION TARGET)
// =============================================================================
// Returns the cookie ISN to embed in the SYN-ACK. Does NOT allocate a TCB.
fn handle_syn(src_ip: u32, dst_ip: u32, src_port: u16, dst_port: u16, client_isn: u32) -> u32 {
    // Stateless: generate cookie, NO pool_alloc()
    return generate_syn_cookie(src_ip, dst_ip, src_port, dst_port, client_isn);
}

// =============================================================================
// handle_ack — Cookie-validated TCB allocation (THE INTEGRATION TARGET)
// =============================================================================
// Validates the cookie from the client's ACK. If valid, allocates a TCB and
// transitions to ESTABLISHED. Returns slot index or 0xFFFFFFFF on failure.
fn handle_ack(src_ip: u32, dst_ip: u32, src_port: u16, dst_port: u16,
              client_isn: u32, ack_isn: u32) -> u64 {
    // Validate the cookie
    if !validate_syn_cookie(ack_isn, src_ip, dst_ip, src_port, dst_port, client_isn) {
        return 0xFFFFFFFF;  // Cookie invalid — drop silently
    }

    // Cookie valid — NOW allocate the TCB
    let slot = pool_alloc();
    if slot == 0xFFFFFFFF {
        return 0xFFFFFFFF;  // Pool exhausted
    }

    POOL[slot].state = TCP_ESTABLISHED;
    POOL[slot].local_port = dst_port;
    POOL[slot].remote_port = src_port;
    POOL[slot].remote_ip = src_ip;
    POOL[slot].seq_snd = ack_isn + 1;
    POOL[slot].seq_rcv = client_isn + 1;

    return slot;
}

extern fn puts(s: &str) -> i32;

// =============================================================================
// TESTS
// =============================================================================

// Test 1: SYN handling does NOT allocate a TCB
fn test_syn_no_tcb_allocation() -> bool {
    pool_clear();
    let before = pool_active_count();

    // Process 100 SYN packets from different sources
    let mut i: u32 = 0;
    while i < 100 {
        let cookie = handle_syn(
            0x0A000001 + i,   // varying src_ip
            0xC0A80001,       // dst_ip
            (40000 + i) as u16, // src_port
            80 as u16,          // dst_port
            (i * 12345) as u32  // client_isn
        );
        // Cookie must be non-zero
        if cookie == 0 {
            return false;
        }
        i = i + 1;
    }

    let after = pool_active_count();
    // Assert: zero TCBs were allocated
    return after == before;
}

// Test 2: Valid ACK validates cookie and allocates TCB
fn test_ack_validates_cookie_then_allocates() -> bool {
    pool_clear();

    let src_ip: u32  = 0x0A000001;
    let dst_ip: u32  = 0xC0A80001;
    let src_port: u16 = 50000;
    let dst_port: u16 = 80;
    let client_isn: u32 = 0xABCD1234;

    // Step 1: SYN → get cookie
    let cookie = handle_syn(src_ip, dst_ip, src_port, dst_port, client_isn);

    // Step 2: ACK → validate cookie, allocate TCB
    let slot = handle_ack(src_ip, dst_ip, src_port, dst_port, client_isn, cookie);

    // Must succeed
    if slot == 0xFFFFFFFF { return false; }

    // TCB must be in ESTABLISHED state
    if POOL[slot].state != TCP_ESTABLISHED { return false; }

    // Connection fields must match
    if POOL[slot].remote_ip != src_ip { return false; }
    if POOL[slot].remote_port != src_port { return false; }
    if POOL[slot].local_port != dst_port { return false; }

    return true;
}

// Test 3: Tampered cookie is rejected
fn test_ack_rejects_tampered_cookie() -> bool {
    pool_clear();

    let src_ip: u32  = 0x0A000001;
    let dst_ip: u32  = 0xC0A80001;
    let src_port: u16 = 50000;
    let dst_port: u16 = 80;
    let client_isn: u32 = 0xABCD1234;

    let cookie = handle_syn(src_ip, dst_ip, src_port, dst_port, client_isn);

    // Tamper: flip a bit in the hash portion
    let tampered = cookie ^ 0x00000100;

    let slot = handle_ack(src_ip, dst_ip, src_port, dst_port, client_isn, tampered);

    // Must FAIL — no TCB allocated
    if slot != 0xFFFFFFFF { return false; }

    // Pool must be empty
    return pool_active_count() == 0;
}

// Test 4: SYN flood cannot exhaust the TCB pool
fn test_syn_flood_no_pool_exhaustion() -> bool {
    pool_clear();

    // Simulate a SYN flood: 1000 SYN packets, zero completed handshakes
    let mut i: u32 = 0;
    while i < 1000 {
        let _cookie = handle_syn(
            0x0A000000 + i,
            0xC0A80001,
            (30000 + (i % 30000)) as u16,
            80 as u16,
            i * 7919
        );
        i = i + 1;
    }

    // Zero TCBs consumed — the flood is completely absorbed
    return pool_active_count() == 0;
}

// Test 5: Full 3-way handshake round trip
fn test_legitimate_handshake_round_trip() -> bool {
    pool_clear();

    // Client A
    let cookie_a = handle_syn(0x0A000001, 0xC0A80001, 50001 as u16, 80 as u16, 0x11111111);
    // Client B
    let cookie_b = handle_syn(0x0A000002, 0xC0A80001, 50002 as u16, 80 as u16, 0x22222222);

    // Both complete handshake
    let slot_a = handle_ack(0x0A000001, 0xC0A80001, 50001 as u16, 80 as u16, 0x11111111, cookie_a);
    let slot_b = handle_ack(0x0A000002, 0xC0A80001, 50002 as u16, 80 as u16, 0x22222222, cookie_b);

    if slot_a == 0xFFFFFFFF { return false; }
    if slot_b == 0xFFFFFFFF { return false; }
    if slot_a == slot_b { return false; }  // Must be different slots

    // Both in ESTABLISHED
    if POOL[slot_a].state != TCP_ESTABLISHED { return false; }
    if POOL[slot_b].state != TCP_ESTABLISHED { return false; }

    // Exactly 2 active connections
    return pool_active_count() == 2;
}

fn main() -> i32 {
    let mut pass: i32 = 0;
    let mut fail: i32 = 0;

    if test_syn_no_tcb_allocation() {
        puts("PASS: test_syn_no_tcb_allocation"); pass = pass + 1;
    } else {
        puts("FAIL: test_syn_no_tcb_allocation"); fail = fail + 1;
    }

    if test_ack_validates_cookie_then_allocates() {
        puts("PASS: test_ack_validates_cookie_then_allocates"); pass = pass + 1;
    } else {
        puts("FAIL: test_ack_validates_cookie_then_allocates"); fail = fail + 1;
    }

    if test_ack_rejects_tampered_cookie() {
        puts("PASS: test_ack_rejects_tampered_cookie"); pass = pass + 1;
    } else {
        puts("FAIL: test_ack_rejects_tampered_cookie"); fail = fail + 1;
    }

    if test_syn_flood_no_pool_exhaustion() {
        puts("PASS: test_syn_flood_no_pool_exhaustion"); pass = pass + 1;
    } else {
        puts("FAIL: test_syn_flood_no_pool_exhaustion"); fail = fail + 1;
    }

    if test_legitimate_handshake_round_trip() {
        puts("PASS: test_legitimate_handshake_round_trip"); pass = pass + 1;
    } else {
        puts("FAIL: test_legitimate_handshake_round_trip"); fail = fail + 1;
    }

    if fail == 0 { return 0; }
    return 1;
}
