// =============================================================================
// Test: Fabric Trait — Headroom Constants and Zero-Copy Contract
// =============================================================================
// Verifies that the FabricCapability abstraction's headroom constants
// are correctly defined for both TCP (54) and RDMA (0) paths.
// =============================================================================

fn main() -> i32 {
    // TCP fabric headroom: Eth(14) + IPv4(20) + TCP(20) = 54
    let tcp_headroom: u32 = 54;
    if tcp_headroom != 54 {
        return 1;
    }

    // RDMA fabric headroom: NIC handles all headers = 0
    let rdma_headroom: u32 = 0;

    // Key invariant: RDMA headroom must be strictly less than TCP
    if rdma_headroom >= tcp_headroom {
        return 2;
    }

    // Allocation math: payload + headroom
    let payload: u32 = 512;
    let tcp_alloc = payload + tcp_headroom;    // 566
    let rdma_alloc = payload + rdma_headroom;  // 512

    if tcp_alloc != 566 {
        return 3;
    }
    if rdma_alloc != 512 {
        return 4;
    }

    // WQE (Work Queue Element) size for RDMA: 16 bytes
    let wqe_size: u32 = 16;
    if wqe_size != 16 {
        return 5;
    }

    return 0;
}
