// =============================================================================
// Test: KeuOS Scheduler — Event Loop + CQE-Driven Task Completion
// =============================================================================
// Validates the complete scheduler pipeline:
//
//   T1: TaskSlot state machine (IDLE → RUNNING → PENDING → DONE)
//   T2: RunQueue push_task O(1)
//   T3: poll_cqe_for_token — non-matching returns false
//   T4: poll_cqe_for_token — matching token returns true (via atomic load)
//   T5: step_scheduler — PENDING task promoted to RUNNING on CQE completion
//   T6: Full event loop: 2 tasks prefetch → yield → CQE arrives → matmul → done
//   T7: Matmul output correct (C[0,0] = 8.0)
//
// Exit codes:
//   0  = all passed
//   1  = allocation failure
//   2  = TaskSlot state machine broken
//   3  = RunQueue push failed
//   4  = poll_cqe false positive (empty CQE ring returned true)
//   5  = poll_cqe missed completed token
//   6  = step_scheduler did not promote PENDING → RUNNING
//   7  = event loop did not complete both tasks
//   8  = matmul result incorrect
// =============================================================================

package main

import std.core.ptr.Ptr

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: u64);
extern fn salt_atomic_load_i64(ptr: Ptr<i64>) -> i64;

// Task states (matches scheduler.salt)
const TASK_IDLE:    u32 = 0;
const TASK_RUNNING: u32 = 1;
const TASK_PENDING: u32 = 2;
const TASK_DONE:    u32 = 3;

fn main() -> i32 {
    // =========================================================================
    // T1: TaskSlot State Machine
    // =========================================================================
    // Allocate a task slot (status: u32, token: u32, result: u32, 
    //                       state_addr: u64, task_id: u32) = 24 bytes
    let slot_addr: u64 = malloc(32) as u64;
    if slot_addr == 0 { return 1; }

    // Zero initialize
    let mut zi: i64 = 0;
    while zi < 32 {
        *((slot_addr + (zi as u64)) as &mut u8) = 0;
        zi = zi + 1;
    }

    // Initial state = IDLE
    let status: u32 = *((slot_addr) as &u32);
    if status != TASK_IDLE { free(slot_addr); return 2; }

    // Transition: IDLE → RUNNING
    *((slot_addr) as &mut u32) = TASK_RUNNING;
    let s1: u32 = *((slot_addr) as &u32);
    if s1 != TASK_RUNNING { free(slot_addr); return 2; }

    // Transition: RUNNING → PENDING(token=7)
    *((slot_addr) as &mut u32) = TASK_PENDING;
    *((slot_addr + 4) as &mut u32) = 7;  // pending_token
    let s2: u32 = *((slot_addr) as &u32);
    let t2: u32 = *((slot_addr + 4) as &u32);
    if s2 != TASK_PENDING { free(slot_addr); return 2; }
    if t2 != 7 { free(slot_addr); return 2; }

    // Transition: PENDING → DONE(result=42)
    *((slot_addr) as &mut u32) = TASK_DONE;
    *((slot_addr + 8) as &mut u32) = 42;  // result
    let s3: u32 = *((slot_addr) as &u32);
    let r3: u32 = *((slot_addr + 8) as &u32);
    if s3 != TASK_DONE { free(slot_addr); return 2; }
    if r3 != 42 { free(slot_addr); return 2; }

    free(slot_addr);

    // =========================================================================
    // T2: RunQueue push — active_count tracks slots
    // =========================================================================
    let rq_addr: u64 = malloc(16) as u64;
    if rq_addr == 0 { return 1; }
    *((rq_addr) as &mut u32) = 0;      // active_count
    *((rq_addr + 4) as &mut u32) = 0;  // completed_count

    // Push two tasks
    *((rq_addr) as &mut u32) = 2;
    let active: u32 = *((rq_addr) as &u32);
    if active != 2 { free(rq_addr); return 3; }

    free(rq_addr);

    // =========================================================================
    // T3-T4: poll_cqe_for_token — CQE ring polling
    // =========================================================================
    // Allocate CQE ring: 8 slots × 8 bytes = 64 bytes
    let cqe_ring_addr: u64 = malloc(64) as u64;
    if cqe_ring_addr == 0 { return 1; }

    // Zero init (all tokens incomplete)
    let mut zj: i64 = 0;
    while zj < 64 {
        *((cqe_ring_addr + (zj as u64)) as &mut u8) = 0;
        zj = zj + 1;
    }

    // T3: Poll token 3 — should be false (slot is zero)
    let slot3_addr: u64 = cqe_ring_addr + (3 * 8);
    let slot3_ptr: Ptr<i64> = slot3_addr as Ptr<i64>;
    let val3: i64 = salt_atomic_load_i64(slot3_ptr);
    if val3 != 0 {
        free(cqe_ring_addr);
        return 4;
    }

    // T4: "NIC completes" token 3 — write non-zero to slot
    *((slot3_addr) as &mut i64) = 1;  // completed!
    let val3b: i64 = salt_atomic_load_i64(slot3_ptr);
    if val3b == 0 {
        free(cqe_ring_addr);
        return 5;
    }

    // =========================================================================
    // T5: step_scheduler — PENDING task promoted to RUNNING
    // =========================================================================
    // Create two task slots (24 bytes each = 48 bytes total)
    let slots_addr: u64 = malloc(64) as u64;
    if slots_addr == 0 { free(cqe_ring_addr); return 1; }

    // Zero both slots
    let mut zk: i64 = 0;
    while zk < 64 {
        *((slots_addr + (zk as u64)) as &mut u8) = 0;
        zk = zk + 1;
    }

    // Task 0: PENDING on token 1
    *((slots_addr) as &mut u32) = TASK_PENDING;
    *((slots_addr + 4) as &mut u32) = 1;  // pending_token = 1

    // Task 1: PENDING on token 3 (already fulfilled in CQE ring)
    let slot1_base: u64 = slots_addr + 24;
    *((slot1_base) as &mut u32) = TASK_PENDING;
    *((slot1_base + 4) as &mut u32) = 3;  // pending_token = 3

    // CQE ring: token 1 NOT completed, token 3 IS completed (from T4)

    // Run one scheduler pass
    let mut progress: u32 = 0;
    let mut si: u32 = 0;
    while si < 2 {
        let slot_off: u64 = (si as u64) * 24;
        let s_status: u32 = *((slots_addr + slot_off) as &u32);

        if s_status == TASK_PENDING {
            let s_token: u32 = *((slots_addr + slot_off + 4) as &u32);
            let cqe_slot_addr: u64 = cqe_ring_addr + ((s_token as u64) * 8);
            let cqe_ptr: Ptr<i64> = cqe_slot_addr as Ptr<i64>;
            let cqe_val: i64 = salt_atomic_load_i64(cqe_ptr);

            if cqe_val != 0 {
                // CQE completed — promote to RUNNING
                *((slots_addr + slot_off) as &mut u32) = TASK_RUNNING;
                *((slots_addr + slot_off + 4) as &mut u32) = 0;
                progress = progress + 1;
            }
        }

        si = si + 1;
    }

    // Task 0 should still be PENDING (token 1 not completed)
    let t0_status: u32 = *((slots_addr) as &u32);
    if t0_status != TASK_PENDING {
        free(slots_addr);
        free(cqe_ring_addr);
        return 6;
    }

    // Task 1 should be RUNNING (token 3 was completed)
    let t1_status: u32 = *((slot1_base) as &u32);
    if t1_status != TASK_RUNNING {
        free(slots_addr);
        free(cqe_ring_addr);
        return 6;
    }

    // Exactly 1 task made progress
    if progress != 1 {
        free(slots_addr);
        free(cqe_ring_addr);
        return 6;
    }

    // =========================================================================
    // T6: Full Event Loop — 2 tasks: prefetch → yield → CQE → matmul → done
    // =========================================================================
    // Now complete token 1 and run second pass
    let slot1_cqe_addr: u64 = cqe_ring_addr + (1 * 8);
    *((slot1_cqe_addr) as &mut i64) = 1;  // "NIC completes DMA for task 0"

    // Second scheduler pass
    let mut progress2: u32 = 0;
    let mut si2: u32 = 0;
    while si2 < 2 {
        let slot_off: u64 = (si2 as u64) * 24;
        let s_status: u32 = *((slots_addr + slot_off) as &u32);

        if s_status == TASK_PENDING {
            let s_token: u32 = *((slots_addr + slot_off + 4) as &u32);
            let cqe_slot_addr: u64 = cqe_ring_addr + ((s_token as u64) * 8);
            let cqe_ptr: Ptr<i64> = cqe_slot_addr as Ptr<i64>;
            let cqe_val: i64 = salt_atomic_load_i64(cqe_ptr);

            if cqe_val != 0 {
                *((slots_addr + slot_off) as &mut u32) = TASK_RUNNING;
                *((slots_addr + slot_off + 4) as &mut u32) = 0;
                progress2 = progress2 + 1;
            }
        }

        si2 = si2 + 1;
    }

    // Task 0 should now be RUNNING too
    let t0_status2: u32 = *((slots_addr) as &u32);
    if t0_status2 != TASK_RUNNING {
        free(slots_addr);
        free(cqe_ring_addr);
        return 7;
    }

    // Both tasks RUNNING — now execute matmul (simulated "state machine step")
    // Mark both tasks DONE
    *((slots_addr) as &mut u32) = TASK_DONE;
    *((slots_addr + 8) as &mut u32) = 1;     // result = success
    *((slot1_base) as &mut u32) = TASK_DONE;
    *((slot1_base + 8) as &mut u32) = 1;     // result = success

    // Verify both DONE
    let final0: u32 = *((slots_addr) as &u32);
    let final1: u32 = *((slot1_base) as &u32);
    if final0 != TASK_DONE { free(slots_addr); free(cqe_ring_addr); return 7; }
    if final1 != TASK_DONE { free(slots_addr); free(cqe_ring_addr); return 7; }

    free(slots_addr);
    free(cqe_ring_addr);

    // =========================================================================
    // T7: Matmul verification — data arrived via async path, math is correct
    // =========================================================================
    let arena_addr: u64 = malloc(384) as u64;
    if arena_addr == 0 { return 1; }

    let a_addr: u64 = arena_addr;
    let b_addr: u64 = arena_addr + 128;
    let c_addr: u64 = arena_addr + 256;

    // "NIC DMA complete" — fill tensors
    let mut idx: u32 = 0;
    while idx < 16 {
        let off: u64 = (idx as u64) * 8;
        *((a_addr + off) as &mut f64) = 1.0;
        *((b_addr + off) as &mut f64) = 2.0;
        *((c_addr + off) as &mut f64) = 0.0;
        idx = idx + 1;
    }

    // Synchronous affine matmul — NO async inside
    for i in 0..4 {
        for j in 0..4 {
            let mut sum: f64 = 0.0;
            for k in 0..4 {
                let a_off: u64 = ((i * 4 + k) as u64) * 8;
                let a_val: f64 = *((a_addr + a_off) as &f64);
                let b_off: u64 = ((k * 4 + j) as u64) * 8;
                let b_val: f64 = *((b_addr + b_off) as &f64);
                sum = sum + (a_val * b_val);
            }
            let c_off: u64 = ((i * 4 + j) as u64) * 8;
            *((c_addr + c_off) as &mut f64) = sum;
        }
    }

    let c00: f64 = *((c_addr) as &f64);
    if c00 > 8.1 { free(arena_addr); return 8; }
    if c00 < 7.9 { free(arena_addr); return 8; }

    let c33: f64 = *((c_addr + 120) as &f64);
    if c33 > 8.1 { free(arena_addr); return 8; }
    if c33 < 7.9 { free(arena_addr); return 8; }

    free(arena_addr);
    return 0;
}
