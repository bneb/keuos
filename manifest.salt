// manifest.salt
// Defines the cohesive "KeuOS Distribution" state of the KeuOS Platform.
// Used by tooling to verify cross-component compatibility.

struct KeuOSManifest {
    platform_version: String,
    compiler: ComponentDef,
    kernel: ComponentDef,
    services: Array<ComponentDef>,
    apps: Array<ComponentDef>,
}

struct ComponentDef {
    name: String,
    version: String,
    milestone: String,
}

pub let CURRENT_MANIFEST = KeuOSManifest {
    platform_version: "0.9.2",
    
    compiler: ComponentDef {
        name: "salt-front",
        version: "0.8.0",
        milestone: "Z3 Verification (requires + ensures), Multi-Dialect Codegen, Path-Sensitive WP",
    },
    
    kernel: ComponentDef {
        name: "keuos-core",
        version: "0.9.2",
        milestone: "16-Core SMP, Chase-Lev Work-Stealing, Preemptive Scheduler, Ring 3 Isolation",
    },
    
    services: [
        ComponentDef {
            name: "netd",
            version: "0.9.2",
            milestone: "Ring 3 Daemon, Zero-Trap Sockets, SYN Cookie Hardening",
        },
        ComponentDef {
            name: "lsp",
            version: "0.2.0",
            milestone: "Zero-I/O in-memory compilation, Z3 semantic hover, Go-to-Definition",
        }
    ],
    
    apps: [
        ComponentDef {
