// =============================================================================
// user/entity_map_test.salt
// Ring 3 test: ECS entity allocation via sys_entity_map
// =============================================================================
package user.entity_map_test

import user.std.stdio

const CONSOLE_ENTITY: u64 = 0xFFFFFFFE;

extern fn sys_getpid() -> u64;
extern fn sys_entity_map(parent_slot: u64, size: u64) -> u64;
extern fn sys_entity_write(entity_val: u64, buf_ptr: u64, buf_len: u64) -> u64;
extern fn sys_exit(code: u64);

pub fn main() {
    let slot = sys_getpid();
    stdio.print("[EM] pid=");
    stdio.print_u64(slot);
    stdio.print("\n");

    let entity_val = sys_entity_map(slot, 4096);

    let msg: [u8; 18] = [91, 69, 77, 93, 32, 101, 110, 116, 105,
                         116, 121, 95, 109, 97, 112, 10, 0, 0];
    let buf_ptr = (&msg[0]) as u64;
    let _ = sys_entity_write(CONSOLE_ENTITY, buf_ptr, 16);

    if entity_val != 0 {
        stdio.print("[EM] entity_map PASS (entity_val=");
        stdio.print_u64(entity_val);
        stdio.print(")\n");
        stdio.print("ENTITY_MAP_PASS\n");
    } else {
        stdio.print("[EM] entity_map FAILED\n");
    }

    sys_exit(42);
}
