    path_cubic_to(&mut ml, 256.0, 358.0, 254.0, 358.0, 254.0, 355.0);
    path_line_to(&mut ml, 254.0, 330.0);
    path_close(&mut ml);
    fill_path(c, &ml, 48, 24, 24, 255);
    path_free(&mut ml);

    // ── Left mouth curve ──
    let mut mc1 = path_new();
    path_move_to(&mut mc1, 254.0, 355.0);
    path_cubic_to(&mut mc1, 240.0, 370.0, 210.0, 380.0, 200.0, 370.0);
    path_cubic_to(&mut mc1, 198.0, 368.0, 208.0, 378.0, 222.0, 373.0);
    path_cubic_to(&mut mc1, 238.0, 367.0, 252.0, 357.0, 254.0, 353.0);
    path_close(&mut mc1);
    fill_path(c, &mc1, 48, 24, 24, 255);
    path_free(&mut mc1);

    // ── Right mouth curve ──
    let mut mc2 = path_new();
    path_move_to(&mut mc2, 258.0, 355.0);
    path_cubic_to(&mut mc2, 272.0, 370.0, 302.0, 380.0, 312.0, 370.0);
    path_cubic_to(&mut mc2, 314.0, 368.0, 304.0, 378.0, 290.0, 373.0);
    path_cubic_to(&mut mc2, 274.0, 367.0, 260.0, 357.0, 258.0, 353.0);
    path_close(&mut mc2);
    fill_path(c, &mc2, 48, 24, 24, 255);
    path_free(&mut mc2);

    // ── Whiskers ──
    // Left whisker 1
    let mut w1 = path_new();
    path_move_to(&mut w1, 170.0, 335.0);
    path_quad_to(&mut w1, 100.0, 320.0, 30.0, 310.0);
    path_quad_to(&mut w1, 100.0, 325.0, 170.0, 338.0);
    path_close(&mut w1);
    fill_path(c, &w1, 32, 32, 32, 255);  // 0x202020FF
    path_free(&mut w1);

    // Left whisker 2
    let mut w2 = path_new();
    path_move_to(&mut w2, 170.0, 350.0);
    path_quad_to(&mut w2, 95.0, 350.0, 25.0, 355.0);
    path_quad_to(&mut w2, 95.0, 354.0, 170.0, 353.0);
    path_close(&mut w2);
    fill_path(c, &w2, 32, 32, 32, 255);
    path_free(&mut w2);

    // Left whisker 3
    let mut w3 = path_new();
    path_move_to(&mut w3, 172.0, 365.0);
    path_quad_to(&mut w3, 105.0, 380.0, 35.0, 400.0);
    path_quad_to(&mut w3, 105.0, 384.0, 172.0, 368.0);
    path_close(&mut w3);
    fill_path(c, &w3, 32, 32, 32, 255);
    path_free(&mut w3);

    // Right whisker 1
    let mut w4 = path_new();
    path_move_to(&mut w4, 342.0, 335.0);
    path_quad_to(&mut w4, 412.0, 320.0, 482.0, 310.0);
    path_quad_to(&mut w4, 412.0, 325.0, 342.0, 338.0);
    path_close(&mut w4);
    fill_path(c, &w4, 32, 32, 32, 255);
    path_free(&mut w4);

    // Right whisker 2
    let mut w5 = path_new();
    path_move_to(&mut w5, 342.0, 350.0);
    path_quad_to(&mut w5, 417.0, 350.0, 487.0, 355.0);
    path_quad_to(&mut w5, 417.0, 354.0, 342.0, 353.0);
    path_close(&mut w5);
    fill_path(c, &w5, 32, 32, 32, 255);
    path_free(&mut w5);

    // Right whisker 3
    let mut w6 = path_new();
    path_move_to(&mut w6, 340.0, 365.0);
    path_quad_to(&mut w6, 407.0, 380.0, 477.0, 400.0);
    path_quad_to(&mut w6, 407.0, 384.0, 340.0, 368.0);
    path_close(&mut w6);
    fill_path(c, &w6, 32, 32, 32, 255);
    path_free(&mut w6);

    // ── Eye highlights (small white circles) ──
    let mut h1 = path_new();
    let h1cx: f32 = 200.0;
    let h1cy: f32 = 216.0;
    let h1r: f32 = 6.0;
    let h1k = 0.5523 * h1r;
    path_move_to(&mut h1, h1cx + h1r, h1cy);
    path_cubic_to(&mut h1, h1cx + h1r, h1cy + h1k, h1cx + h1k, h1cy + h1r, h1cx, h1cy + h1r);
    path_cubic_to(&mut h1, h1cx - h1k, h1cy + h1r, h1cx - h1r, h1cy + h1k, h1cx - h1r, h1cy);
    path_cubic_to(&mut h1, h1cx - h1r, h1cy - h1k, h1cx - h1k, h1cy - h1r, h1cx, h1cy - h1r);
    path_cubic_to(&mut h1, h1cx + h1k, h1cy - h1r, h1cx + h1r, h1cy - h1k, h1cx + h1r, h1cy);
    path_close(&mut h1);
    fill_path(c, &h1, 255, 255, 255, 224);  // 0xFFFFFFE0
    path_free(&mut h1);

    let mut h2 = path_new();
    let h2cx: f32 = 322.0;
    let h2cy: f32 = 216.0;
    let h2r: f32 = 6.0;
    let h2k = 0.5523 * h2r;
    path_move_to(&mut h2, h2cx + h2r, h2cy);
    path_cubic_to(&mut h2, h2cx + h2r, h2cy + h2k, h2cx + h2k, h2cy + h2r, h2cx, h2cy + h2r);
    path_cubic_to(&mut h2, h2cx - h2k, h2cy + h2r, h2cx - h2r, h2cy + h2k, h2cx - h2r, h2cy);
    path_cubic_to(&mut h2, h2cx - h2r, h2cy - h2k, h2cx - h2k, h2cy - h2r, h2cx, h2cy - h2r);
    path_cubic_to(&mut h2, h2cx + h2k, h2cy - h2r, h2cx + h2r, h2cy - h2k, h2cx + h2r, h2cy);
    path_close(&mut h2);
    fill_path(c, &h2, 255, 255, 255, 224);
    path_free(&mut h2);
}

// ═══════════════════════════════════════════════════════════════
// Main — Benchmark Loop
// ═══════════════════════════════════════════════════════════════

fn main() -> i32 {
    let width: i32 = 512;
    let height: i32 = 512;
    let warmup: i32 = 3;
    let iterations: i32 = 20;

    println("═══════════════════════════════════════════");
    println("  Facet Tiger Benchmark — Salt (MLIR)");
    println("═══════════════════════════════════════════");
    println(f"Canvas: {width}x{height}, Iterations: {iterations}");

    let mut c = canvas_new(width, height);
    let mut checksum_acc: i64 = 0;

    // Warmup
    let mut wi: i32 = 0;
    while wi < warmup {
        canvas_clear(&mut c, 404628735);  // 0x181820FF
        build_tiger(&mut c);
        wi = wi + 1;
    }

    // Timed iterations
    let start = Instant::now();

    let mut iter: i32 = 0;
    while iter < iterations {
        canvas_clear(&mut c, 404628735);
        build_tiger(&mut c);
        checksum_acc = checksum_acc + canvas_checksum(&c);  // DCE guard
        iter = iter + 1;
    }

    let elapsed = start.elapsed();
    let elapsed_us = elapsed.as_nanos() / 1000;
    let per_frame_us = elapsed_us / (iterations as i64);

    println(f"  Total:      {elapsed_us} us ({iterations} frames)");
    println(f"  Per frame:  {per_frame_us} us");

    let fps = 1000000 / per_frame_us;
    println(f"  Throughput: {fps} frames/sec");
    println(f"  Checksum:   {checksum_acc} (DCE guard)");

    // Golden image checksum
    canvas_clear(&mut c, 404628735);
    build_tiger(&mut c);
    let golden = canvas_checksum(&c);
    println(f"  Golden:     {golden}");

    canvas_free(&mut c);
    return 0;
}
