package basalt

// Yield Validation: exercises the yield pulse injection path
// The compiler's stride-1024 yield check should fire in tight loops.

fn stress_test_task_a() -> i64 {
    let mut count: i64 = 0;
    for i in 0..1000000 {
        count = count + 1;
    }
    return count;
}

fn stress_test_task_b() -> i64 {
    let mut count: i64 = 0;
    for i in 0..1000000 {
        count = count + 1;
    }
    return count;
}

fn main() -> i32 {
    let a = stress_test_task_a();
    let b = stress_test_task_b();
    if a != 1000000 { return 1; }
    if b != 1000000 { return 2; }
    return 0;
}
