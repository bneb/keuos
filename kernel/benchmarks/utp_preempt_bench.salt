// UTP Preemptive Dispatch Latency Benchmark
// Measures the cost of the full IRETQ chain:
//   sched_yield → invoke_task(ipt, ctx) → push callee-saved → save RSP →
//   pop 15 GPRs → IRETQ → thread returns → trampoline → restore RSP →
//   pop callee-saved → POLL_READY
//
// On KVM, expected ~50-100 cycles. On TCG, inflated but functional.

package benchmarks.utp_preempt_bench

import kernel.drivers.serial
import kernel.drivers.vga
import kernel.core.timing

extern fn sched_spawn(entry_addr: u64) -> u64;
extern fn sched_yield();
extern fn fiber_count() -> u64;

const NUM_SAMPLES: i32 = 100;
const MIN_CYCLES: i64 = 1;
const MAX_CYCLES: i64 = 10000000;

// Trivial worker: immediately returns. ret lands in preemptive_exit_trampoline
// which restores scheduler RSP and returns POLL_READY.
pub fn bench_preempt_noop() {
    // Do nothing. Just return.
}

@no_mangle
pub fn run_utp_preempt_bench() {
    serial.print("BENCH:utp_preempt:start\n");
    vga.print("UTP preempt dispatch...\n");

    let mut total: i64 = 0;
    let mut valid: i32 = 0;
    let mut min_cy: i64 = 999999999;
    let mut max_cy: i64 = 0;

    for i in 0..NUM_SAMPLES {
        let count_before = fiber_count();

        // Spawn a preemptive fiber that immediately returns
        let slot = sched_spawn(fn_addr(bench_preempt_noop));
        if slot >= 256 { continue; }

        // Measure the yield+dispatch through the full IRETQ chain.
        // CRITICAL: If the PIT timer preempts the noop fiber before its
        // `ret`, sched_yield returns POLL_PENDING and the fiber stays alive.
        // We MUST keep yielding until the fiber actually completes, otherwise
        // we leak bitmap slots and slab stacks → eventual #DF.
        let t0 = timing.get_cycles() as i64;
        loop {
            sched_yield();
            if fiber_count() <= count_before { break; }
        }
        let t1 = timing.get_cycles() as i64;

        let elapsed = t1 - t0;

        if elapsed >= MIN_CYCLES {
            if elapsed <= MAX_CYCLES {
                total += elapsed;
                valid += 1;
                if elapsed < min_cy { min_cy = elapsed; }
                if elapsed > max_cy { max_cy = elapsed; }
            }
        }
    }

    if valid > 0 {
        let avg = total / (valid as i64);
        serial.print("BENCH:utp_preempt:avg=");
        serial.print_u64(avg as u64);
        serial.print(" min=");
        serial.print_u64(min_cy as u64);
        serial.print(" max=");
        serial.print_u64(max_cy as u64);
        serial.print(" valid=");
        serial.print_u64(valid as u64);
        serial.print("\n");

        vga.print("  UTP preempt avg: ");
        vga.print_u64(avg as u64);
        vga.print(" cycles\n");
    } else {
        serial.print("BENCH:utp_preempt:ERROR no valid samples\n");
        vga.print("  UTP preempt: ERROR\n");
    }
}
