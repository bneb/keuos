// IPC Ping-Pong Benchmark
// Measures fiber-to-fiber message round-trip latency via cooperative yield.
// Uses volatile assembly helpers to prevent load hoisting in spin-wait loops,
// avoiding salt-opt crash from atomicrmw operations.

package benchmarks.ipc_bench

import kernel.drivers.serial
import kernel.drivers.vga
import kernel.core.timing

extern fn volatile_read_i32(addr: u64) -> i32;
extern fn volatile_write_i32(addr: u64, val: i32);
extern fn volatile_read_i64(addr: u64) -> i64;
extern fn volatile_write_i64(addr: u64, val: i64);
extern fn sched_yield();

const NUM_SAMPLES: i32 = 10;
const MIN_CYCLES: i64 = 100;
const MAX_CYCLES: i64 = 10000000;  // Accommodate high fiber counts (post-ROF1K)

// Shared communication channel (plain vars, volatile access via assembly)
var MAILBOX: i64 = 0;
var IPC_TOKEN: i32 = 0;
var IPC_DONE: i32 = 0;

// Responder fiber (spawned from main.salt)
@no_mangle
pub fn ipc_responder() {
    let token_addr = (&IPC_TOKEN) as u64;
    let mailbox_addr = (&MAILBOX) as u64;
    let done_addr = (&IPC_DONE) as u64;

    for count in 0..NUM_SAMPLES {
        // Spin-wait for sender signal (volatile read prevents hoisting)
        while volatile_read_i32(token_addr) != 1 {
            sched_yield();
        }

        // Acknowledge: read mailbox, signal back
        let _msg = volatile_read_i64(mailbox_addr);
        volatile_write_i32(token_addr, 2);

        sched_yield();
    }

    // Signal done and exit fiber
    // NOTE: infinite loop removed — salt-opt SIGSEGV on cf.br back-edge
    volatile_write_i32(done_addr, 1);
    return;
}

@no_mangle
pub fn run_ipc_bench() {
    serial.print("BENCH:ipc:start\n");
    vga.print("IPC ping-pong (10 samples)...\n");

    // NOTE: ipc_responder must already be spawned by caller (main.salt)

    let token_addr = (&IPC_TOKEN) as u64;
    let mailbox_addr = (&MAILBOX) as u64;

    let mut total: i64 = 0;
    let mut valid: i32 = 0;
    let mut min_cy: i64 = 999999999;
    let mut max_cy: i64 = 0;

    for i in 0..NUM_SAMPLES {
        let t0 = timing.get_cycles() as i64;

        // Send: write timestamp, signal responder
        volatile_write_i64(mailbox_addr, t0);
        volatile_write_i32(token_addr, 1);
        sched_yield();

        // Wait for responder acknowledgment (volatile read)
        while volatile_read_i32(token_addr) != 2 {
            sched_yield();
        }

        let t1 = timing.get_cycles() as i64;

        // Reset token for next round
        volatile_write_i32(token_addr, 0);

        let elapsed = t1 - t0;

        if elapsed >= MIN_CYCLES {
            if elapsed <= MAX_CYCLES {
                total += elapsed;
                valid += 1;
                if elapsed < min_cy {
                    min_cy = elapsed;
                }
                if elapsed > max_cy {
                    max_cy = elapsed;
                }
            }
        }
    }

    if valid > 0 {
        let avg = total / (valid as i64);
        serial.print("BENCH:ipc:avg=");
        serial.print_u64(avg as u64);
        serial.print(" min=");
        serial.print_u64(min_cy as u64);
        serial.print(" max=");
        serial.print_u64(max_cy as u64);
        serial.print(" valid=");
        serial.print_u64(valid as u64);
        serial.print("\n");

        vga.print("  IPC avg: ");
        vga.print_u64(avg as u64);
        vga.print(" cycles\n");
    } else {
        serial.print("BENCH:ipc:ERROR no valid samples\n");
        vga.print("  IPC: ERROR\n");
    }
}
