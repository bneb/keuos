// =============================================================================
// Slab Stress Benchmark — ABA-Proof Treiber Stack Under Sustained Load
// =============================================================================
// Stresses the lock-free slab allocator with interleaved alloc/free cycles,
// forcing every pop_stack() through the Treiber stack CAS path (not the bump
// allocator). This is the definitive benchmark for the ABA-proof design.
//
// Methodology:
//   Phase 1 — Warmup: Alloc 256 slots, free them all. This primes the free
//             list so subsequent pops go through the CAS path.
//   Phase 2 — Stress: 10,000 iterations of (pop_stack → push_stack). Each
//             pair exercises one lock cmpxchgq in pop and one in push.
//   Phase 3 — Integrity: Verify watermark hasn't grown (no memory leaks).
//
// Expected: 100-500 cycles/pair (bare metal), 500-5000 (TCG)
// =============================================================================

package benchmarks.slab_stress_bench

import kernel.drivers.serial
import kernel.drivers.vga
import kernel.core.timing

extern fn pop_stack() -> u64;
extern fn push_stack(ptr: u64);
extern fn slab_watermark() -> i32;

const WARMUP_SLOTS: i32 = 16;
const STRESS_ITERS: i32 = 200;
const MIN_CYCLES: u64 = 1;
const MAX_CYCLES: u64 = 500000;

@no_mangle
pub fn run_slab_stress() {
    serial.print("BENCH:slab_stress:start\n");
    vga.print("Slab stress benchmark...\n");

    // ── Phase 1: Warmup — prime the free list ────────────────────────
    let mut warmup_addrs: [u64; 16] = [0; 16];
    for i in 0..WARMUP_SLOTS {
        warmup_addrs[i] = pop_stack();
        if warmup_addrs[i] == 0 {
            serial.print("BENCH:slab_stress:FAIL warmup OOM at i=");
            serial.print_u64(i as u64);
            serial.print("\n");
            return;
        }
    }
    serial.print("BENCH:slab_stress:phase1_warmup_alloc_done\n");

    // Free all warmup slots — now the free list has entries
    for j in 0..WARMUP_SLOTS {
        push_stack(warmup_addrs[j]);
    }
    serial.print("BENCH:slab_stress:phase1_warmup_free_done\n");

    let watermark_before = slab_watermark();

    // ── Phase 2: Stress — interleaved alloc/free ─────────────────────
    serial.print("BENCH:slab_stress:phase2_stress_begin\n");
    let mut total: u64 = 0;
    let mut valid: i32 = 0;
    let mut min_cy: u64 = 0xFFFFFFFFFFFFFFFF;
    let mut max_cy: u64 = 0;

    for k in 0..STRESS_ITERS {
        let t0 = timing.get_cycles();
        let slot = pop_stack();
        push_stack(slot);
        let t1 = timing.get_cycles();

        if slot == 0 {
            serial.print("BENCH:slab_stress:FAIL pop returned 0 at k=");
            serial.print_u64(k as u64);
            serial.print("\n");
            return;
        }

        let elapsed = t1 - t0;
        if elapsed >= MIN_CYCLES {
            if elapsed <= MAX_CYCLES {
                total = total + elapsed;
                valid = valid + 1;
                if elapsed < min_cy { min_cy = elapsed; }
                if elapsed > max_cy { max_cy = elapsed; }
            }
        }
    }

    let watermark_after = slab_watermark();

    // ── Phase 3: Integrity — verify no leaks ─────────────────────────
    let stable = watermark_after == watermark_before;

    // ── Report ───────────────────────────────────────────────────────
    if valid > 0 {
        let avg = total / (valid as u64);
        serial.print("BENCH:slab_stress:avg=");
        serial.print_u64(avg);
        serial.print(" min=");
        serial.print_u64(min_cy);
        serial.print(" max=");
        serial.print_u64(max_cy);
        serial.print(" pairs=");
        serial.print_u64(valid as u64);
        serial.print(" watermark_stable=");
        if stable {
            serial.print("true");
        } else {
            serial.print("false");
        }
        serial.print("\n");

        vga.print("  Slab stress avg: ");
        vga.print_u64(avg);
        vga.print(" cycles/pair\n");
    } else {
        serial.print("BENCH:slab_stress:ERROR no valid samples\n");
        vga.print("  Slab stress: ERROR\n");
    }
}
