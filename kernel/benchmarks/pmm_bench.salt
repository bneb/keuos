// =============================================================================
// PMM Page Alloc/Free Benchmark — Physical Memory Manager Throughput
// =============================================================================
// Measures the raw cost of physical page allocation and deallocation through
// pmm.alloc() and pmm.free(). Uses interleaved alloc/free pairs to avoid
// depleting the kernel's physical page pool.
//
// Methodology:
//   Each iteration allocates one page, then immediately frees it. This
//   measures the full round-trip cost of the PMM Treiber stack. The page
//   is returned before the next iteration, so the kernel never loses pages.
//
// Expected: 50-200 cycles/pair (bare metal), 300-5000 (TCG)
// =============================================================================

package benchmarks.pmm_bench

import kernel.drivers.serial
import kernel.drivers.vga
import kernel.core.timing

// pmm.salt benchmark wrappers (@no_mangle)
extern fn pmm_alloc() -> u64;
extern fn pmm_free(page: u64);

const NUM_ITERS: i32 = 500;
const MIN_CYCLES: u64 = 1;
const MAX_CYCLES: u64 = 500000;

@no_mangle
pub fn run_pmm_bench() {
    serial.print("BENCH:pmm:start\n");
    vga.print("PMM benchmark...\n");

    let mut total: u64 = 0;
    let mut valid: i32 = 0;
    let mut min_cy: u64 = 0xFFFFFFFFFFFFFFFF;
    let mut max_cy: u64 = 0;

    for i in 0..NUM_ITERS {
        let t0 = timing.get_cycles();
        let page = pmm_alloc();
        let t1 = timing.get_cycles();

        if page == 0 {
            serial.print("BENCH:pmm:WARNING OOM at i=");
            serial.print_u64(i as u64);
            serial.print("\n");
            break;
        }

        // Immediately free — keeps the pool stable
        pmm_free(page);
        let t2 = timing.get_cycles();

        let alloc_elapsed = t1 - t0;
        let total_elapsed = t2 - t0;

        if total_elapsed >= MIN_CYCLES {
            if total_elapsed <= MAX_CYCLES {
                total = total + total_elapsed;
                valid = valid + 1;
                if total_elapsed < min_cy { min_cy = total_elapsed; }
                if total_elapsed > max_cy { max_cy = total_elapsed; }
            }
        }
    }

    // ── Report ───────────────────────────────────────────────────────
    if valid > 0 {
        let avg = total / (valid as u64);

        serial.print("BENCH:pmm:avg=");
        serial.print_u64(avg);
        serial.print(" min=");
        serial.print_u64(min_cy);
        serial.print(" max=");
        serial.print_u64(max_cy);
        serial.print(" pairs=");
        serial.print_u64(valid as u64);
        serial.print("\n");

        vga.print("  PMM avg: ");
        vga.print_u64(avg);
        vga.print(" cycles/pair\n");
    } else {
        serial.print("BENCH:pmm:ERROR no valid samples\n");
        vga.print("  PMM: ERROR\n");
    }
}
