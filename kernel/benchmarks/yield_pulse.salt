// Heartbeat Pulse Test
// Validates the Gauntlet P99 metrics by checking yielding every 1024 iterations.

@yielding(1024)
fn task_alpha() -> i32 {
    let mut count = 0;
    for i in 0..1000000 {
        count = count + 1;
    }
    return count;
}

@yielding(1024)
fn task_beta() -> i32 {
    let mut count = 0;
    for i in 0..1000000 {
        count = count + 1;
    }
    return count;
}

fn main() -> i32 {
    let a = task_alpha();
    let b = task_beta();
    return a + b;
}
