// =============================================================================
// benchmarks/net_echo_bench.salt
// Network Echo Benchmark — VirtIO-Net RX/TX Throughput
// =============================================================================
//
// Initializes the VirtIO-Net driver and runs a poll loop serving UDP echo
// on port 7. Reports packets handled via serial.
//
// This benchmark is passive: it relies on the host sending UDP packets to
// the QEMU guest (e.g. via `nc -u localhost 5555`). The benchmark polls
// for a fixed number of cycles and reports the results.
//
// Expected QEMU flags:
//   -device virtio-net-pci,netdev=net0
//   -netdev user,id=net0,hostfwd=udp::5555-:7
//
// Expected serial output:
//   BENCH:net_echo:start
//   NET: VirtIO-Net initialized, 64 RX buffers posted
//   BENCH:net_echo:listening port=7
//   BENCH:net_echo:PASS driver initialized
// =============================================================================

package benchmarks.net_echo_bench

import kernel.drivers.serial
import kernel.drivers.vga
import kernel.drivers.virtio_net
import kernel.net.netcore
import kernel.core.scheduler

@no_mangle
pub fn run_net_echo() {
    serial.print("BENCH:net_echo:start\n");
    vga.print("Net echo benchmark...\n");

    // 1. Initialize the VirtIO-Net driver
    let ok = virtio_net.init();

    if !ok {
        serial.print("BENCH:net_echo:SKIP no virtio-net device\n");
        vga.print_colored("  Net echo: SKIP (no device)\n", 0x0E);
        return;
    }

    serial.print("BENCH:net_echo:listening port=7\n");

    // 2. Poll for packets with yield interleaving.
    // Iteration-based (not rdtsc) for TCG compatibility.
    // Yield frequently to give QEMU's I/O thread time to process
    // packets and complete the ARP handshake before UDP delivery.
    for polls in 0..50000 {
        netcore.poll_all();

        // Yield every 500 polls to balance between I/O time and TCG overhead
        if (polls % 500) == 0 {
            scheduler.yield_now();
        }
    }

    // 3. Report stats
    let rx = virtio_net.get_rx_count();
    let tx = virtio_net.get_tx_count();
    let udp = netcore.get_udp_count();

    serial.print("BENCH:net_echo:result rx=");
    serial.print_u64(rx);
    serial.print(" tx=");
    serial.print_u64(tx);
    serial.print(" udp_echo=");
    serial.print_u64(udp);
    serial.print("\n");

    serial.print("BENCH:net_echo:PASS driver initialized\n");
    vga.print_colored("  Net echo: PASS\n", 0x0A);
}
