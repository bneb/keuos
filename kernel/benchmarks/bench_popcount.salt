import std.math.popcount_u64
import std.io.println

pub fn main() -> i32 {
    let mut x: u64 = 0x5555555555555555; // Alternating bits
    let iterations = 10000000;
    let mut i = 0;
    let mut total: u64 = 0;
    while i < iterations {
        total = total + popcount_u64(x);
        i = i + 1;
    }
    println(f"10M Popcounts Complete. Total: {total}");
    return 0;
}
