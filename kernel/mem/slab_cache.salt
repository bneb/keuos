// =============================================================================
// kernel/mem/slab_cache.salt
// General-Purpose O(1) Cache-Based Object Allocator
// =============================================================================
//
// PMM-backed slab allocator for fixed-size kernel objects (VMA, etc.).
// Each cache manages objects of a single size with:
//   - O(1) allocation via embedded Treiber stack freelist
//   - O(1) deallocation with push-to-freelist
//   - Apple-style 8-byte Redzone buffer overflow detection
//   - Security zeroing on allocation (user region only)
//
// Layout of each object slot within a 4KB PMM page:
//   [0 .. user_obj_size-1]  : User data (security-zeroed on alloc)
//   [user_obj_size .. +7]   : Redzone sentinel (0xDEADBEEF)
//
// When free, the first 8 bytes of user data hold the next-pointer
// for the embedded Treiber stack.
//
// Cache Registry:
//   A single PMM page holds up to MAX_CACHES ObjectCache descriptors.
//   Each descriptor is 32 bytes (4 x u64 fields), packed contiguously.
// =============================================================================

package kernel.mem.slab_cache

import kernel.core.memory
import kernel.core.pmm
import kernel.core.panic
import kernel.drivers.serial
import kernel.core.percpu

// SMP Safety: disable/enable interrupts for critical sections
extern fn disable_interrupts();
// =============================================================================
// Constants
// =============================================================================
const PAGE_SIZE: u64 = 4096;
pub const MAX_CACHES: u64 = 16;
// Per-CPU accessor


// Atomic intrinsics for lock-free Treiber stack (CAS)
extern fn atomic_cas_i64(addr: u64, expected: i64, desired: i64) -> i64;
extern fn spin_loop_hint();

// Redzone magic to detect buffer overflows
const REDZONE_MAGIC: u64 = 0xDEADBEEFCAFEBABE;

// ObjectCache descriptor layout (32 bytes per cache, stored in registry page):
//   offset 0:  is_active     (u64)  — 1 if cache is live, 0 if slot free
//   offset 8:  user_obj_size (u64)  — aligned requested size
//   offset 16: slot_size     (u64)  — user_obj_size + 8 (Redzone)
//   offset 24: free_list_head(u64)  — virtual address of first free slot
const CACHE_STRIDE: u64 = 32;

// =============================================================================
// Globals
// =============================================================================

// Virtual address of the PMM page holding the cache registry
global CACHE_REGISTRY: u64 = 0;

// Next available cache ID (monotonically increasing)
global NEXT_CACHE_ID: u64 = 0;

// =============================================================================
// init — Initialize the cache registry. Called once during kernel boot.
// =============================================================================
pub fn init() {
    let phys = pmm.alloc();
    if phys == 0 {
        panic.panic("slab_cache: OOM initializing registry");
    }
    let virt = memory.phys_to_virt(memory.PhysAddr { val: phys }).val;

    // Zero the entire registry page
    let mut i: u64 = 0;
    while i < PAGE_SIZE {
        *((virt + i) as &mut u8) = 0;
        i = i + 1;
    }

    CACHE_REGISTRY = virt;
    serial.print("[slab_cache] Registry initialized\n");
}

// =============================================================================
// create_cache — Register a new object cache for the given size.
// Returns a cache_id (index into the registry).
// =============================================================================
pub fn create_cache(requested_size: u64) -> u64 {
    if NEXT_CACHE_ID >= MAX_CACHES {
        panic.panic("slab_cache: MAX_CACHES exceeded");
    }

    // 1. Align size to 8 bytes
    let aligned_size = (requested_size + 7) & 0xFFFFFFFFFFFFFFF8;

    // 2. Add 8 bytes for the Redzone sentinel
    let total_slot_size = aligned_size + 8;

    // 3. Populate the ObjectCache descriptor in the registry
    let cache_id = NEXT_CACHE_ID;
    NEXT_CACHE_ID = NEXT_CACHE_ID + 1;

    let base = CACHE_REGISTRY + (cache_id * CACHE_STRIDE);
    *((base + 0) as &mut u64) = 1;                // is_active
    *((base + 8) as &mut u64) = aligned_size;      // user_obj_size
    *((base + 16) as &mut u64) = total_slot_size;  // slot_size
    *((base + 24) as &mut u64) = 0;                // free_list_head (empty)

    serial.print("[slab_cache] Cache created: obj_size=");
    serial.print_u64(aligned_size);
    serial.print(" slot_size=");
    serial.print_u64(total_slot_size);
    serial.print("\n");

    return cache_id;
}

// =============================================================================
// grow_cache — Request a PMM page and carve it into freelist-linked slots.
// Returns 1 on success, 0 on OOM. Strict OOM propagation.
// =============================================================================
fn grow_cache(cache_id: u64) -> u64 {
    let base = CACHE_REGISTRY + (cache_id * CACHE_STRIDE);
    let user_obj_size = *((base + 8) as &u64);
    let slot_size = *((base + 16) as &u64);
    let old_head = *((base + 24) as &u64);

    // Allocate a fresh 4KB page from PMM
    let phys = pmm.alloc();
    if phys == 0 {
        return 0;  // STRICT OOM PROPAGATION
    }

    let page_virt = memory.phys_to_virt(memory.PhysAddr { val: phys }).val;
    let objects_per_page = PAGE_SIZE / slot_size;

    // Carve the page into slots, wiring the embedded freelist
    let mut i: u64 = 0;
    while i < objects_per_page {
        let current = page_virt + (i * slot_size);

        // 1. Write Redzone sentinel at the end of the user data region
        let redzone_ptr = (current + user_obj_size) as &mut u64;
        *redzone_ptr = REDZONE_MAGIC;

        // 2. Wire embedded freelist
        if i < (objects_per_page - 1) {
            // Point to the next slot in this page
            let next = current + slot_size;
            *(current as &mut u64) = next;
        }

        i = i + 1;
    }

    // 3. Update cache head to the first slot of the new page
    // We use a CAS loop here to safely append the grown page to the freelist
    // even if multiple cores concurrently attempt to grow the cache.
    let head_addr = base + 24;
    let mut current_head = old_head;
    let mut success = false;
    
    while !success {
        // Last slot chains to whatever the current freelist head is
        let last_slot = page_virt + ((objects_per_page - 1) * slot_size);
        *(last_slot as &mut u64) = current_head;
        
        let cas_res = atomic_cas_i64(head_addr, current_head as i64, page_virt as i64) as u64;
        if cas_res == current_head {
            success = true;
        } else {
            current_head = cas_res;
            spin_loop_hint();
        }
    }
    return 1;
}

// =============================================================================
// alloc — O(1) object allocation from a cache.
// Returns a virtual address (0 on OOM).
// Security: Zeroes the user region. Does NOT overwrite the Redzone.
// =============================================================================
pub fn alloc(cache_id: u64) -> u64 {
    // Lock-free atomic Compare-And-Swap (CAS) loop
    // to protect the freelist from concurrent modification on SMP.
    let base = CACHE_REGISTRY + (cache_id * CACHE_STRIDE);
    let user_obj_size = *((base + 8) as &u64);
    let head_addr = base + 24;

    let mut allocated: u64 = 0;
    let mut success = false;
    
    while !success {
        // 1. Check freelist head
        let mut head = *(head_addr as &u64);
        if head == 0 {
            let grown = grow_cache(cache_id);
            if grown == 0 {
                return 0;  // OOM
            }
            continue;
        }

        // 2. Pop the head of the Treiber stack using CAS
        let next = *(head as &u64);
        let cas_res = atomic_cas_i64(head_addr, head as i64, next as i64) as u64;
        if cas_res == head {
            allocated = head;
            success = true;
        } else {
            spin_loop_hint();
        }
    }

    // 3. Security zeroing: clear user_obj_size bytes (8-byte aligned)
    //    DO NOT TOUCH THE REDZONE — it must remain intact.
    //    Note: zeroing happens AFTER re-enabling interrupts since it's safe
    //    (the object is now exclusively owned by this caller).
    let mut offset: u64 = 0;
    while offset < user_obj_size {
        *((allocated + offset) as &mut u64) = 0;
        offset = offset + 8;
    }

    return allocated;
}

// =============================================================================
// free — O(1) object deallocation with Redzone validation.
// FATAL PANIC if buffer overflow is detected.
// =============================================================================
pub fn free(cache_id: u64, ptr: u64) {
    if ptr == 0 { return; }

    let base = CACHE_REGISTRY + (cache_id * CACHE_STRIDE);
    let user_obj_size = *((base + 8) as &u64);

    // 1. Apple Redzone Validation (safe to check outside critical section)
    let redzone_ptr = (ptr + user_obj_size) as &u64;
    if *redzone_ptr != REDZONE_MAGIC {
        serial.print("[slab_cache] FATAL: REDZONE CORRUPTION at 0x");
        serial.print_u64(ptr);
        serial.print("\n");
        panic.panic("slab_cache: BUFFER OVERFLOW DETECTED");
    }

    // Lock-free atomic CAS loop to protect the freelist.
    let head_addr = base + 24;
    let mut current_head = *(head_addr as &u64);
    let mut success = false;
    
    while !success {
        // 2. Push object back onto the Treiber stack
        *(ptr as &mut u64) = current_head;
        let cas_res = atomic_cas_i64(head_addr, current_head as i64, ptr as i64) as u64;
        if cas_res == current_head {
            success = true;
        } else {
            current_head = cas_res;
            spin_loop_hint();
        }
    }
}

// @no_mangle ABI Wrappers
@no_mangle
pub fn slab_cache_init() { init(); }

