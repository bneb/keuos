// =============================================================================
// kernel/lib/ipc_arbiter.salt
// IPC Descriptor Arbiter — SipHash-2-4 Hardened (Directive 2.2 + 2.3)
// =============================================================================
//
// This module implements the O(1) fast-path validation for SpscDescriptors.
// It is the NetD arbiter's "trust boundary" — the single checkpoint that
// determines whether a Ring 3 process is authorized to access shared memory.
//
// Directive 2.3 (Hardening): Upgraded from FNV-1a to SipHash-2-4 for
// industry-standard collision resistance and hash-flooding defense.
//
// Validation has two gates (< 12 CPU cycles total):
//
//   Gate 1 — Mechanical Check:
//     (desc.ptr & 0x3F) == 0
//     Confirms the pointer is 64-byte aligned (cache-line isolated).
//     Catches Vector A: Alignment Subversion.
//
//   Gate 2 — Logical Check:
//     desc.proof_hint == authorized_hint
//     Confirms the SipHash-2-4 sealed proof matches the arbiter's contract.
//     Catches Vector B: Hint Forgery.
//
// "Aerospace Brutalism" guarantees:
//   - Zero malloc in the validation path
//   - Zero branch misprediction (99.99% success case → predictor-friendly)
//   - Constant-time comparison (no timing side channels)
// =============================================================================

package kernel.lib.ipc_arbiter

// =============================================================================
// SipHash-2-4 KeuOS Keys
// =============================================================================
// These MUST match the values in:
//   salt-front/src/codegen/verification/proof_hint.rs
//   SIPHASH_K0 = 0x4c61747469636521  ("KeuOS!")
//   SIPHASH_K1 = 0x536f76657265696e  ("Soverein")
// =============================================================================

pub const SIPHASH_K0: u64 = 0x4c61747469636521;
pub const SIPHASH_K1: u64 = 0x536f76657265696e;

// =============================================================================
// SipHash-2-4 Initialization Vector Constants
// =============================================================================

pub const SIP_C0: u64 = 0x736f6d6570736575;  // "somepseu"
pub const SIP_C1: u64 = 0x646f72616e646f6d;  // "dorandom"
pub const SIP_C2: u64 = 0x6c7967656e657261;  // "lygenera"
pub const SIP_C3: u64 = 0x7465646279746573;  // "tedbytes"

// =============================================================================
// sip_round — ARX (Add-Rotate-Xor) core round
// =============================================================================
// Each round performs 4 additions, 4 rotations, and 4 XORs on the 256-bit
// state (v0, v1, v2, v3). This is the primitive that gives SipHash its
// collision resistance.
//
// MUST produce identical state transitions to the Rust implementation.
// =============================================================================

pub fn sip_round(v0: u64, v1: u64, v2: u64, v3: u64) -> u64 {
    // Salt limitation: no mutable reference parameters yet.
    // We use a packed return value and caller unpacks.
    // For now, this returns v0 only — caller chains calls.
    //
    // Full implementation inlined in siphash24 below.
    return v0;
}

// =============================================================================
// siphash24 — SipHash-2-4 for a single 64-bit message word
// =============================================================================
// 2 compression rounds + 4 finalization rounds.
// This MUST produce identical output to the Rust compiler's siphash24().
// =============================================================================

pub fn siphash24(k0: u64, k1: u64, m: u64) -> u64 {
    let v0: u64 = k0 ^ SIP_C0;
    let v1: u64 = k1 ^ SIP_C1;
    let v2: u64 = k0 ^ SIP_C2;
    let v3: u64 = k1 ^ SIP_C3;

    // Compress message
    v3 = v3 ^ m;

    // --- Compression Round 1 ---
    v0 = v0 + v1;  v2 = v2 + v3;
    v1 = ((v1 << 13) | (v1 >> 51));  // rotate_left(13)
    v3 = ((v3 << 16) | (v3 >> 48));  // rotate_left(16)
    v1 = v1 ^ v0;  v3 = v3 ^ v2;
    v0 = ((v0 << 32) | (v0 >> 32));  // rotate_left(32)
    v2 = v2 + v1;  v0 = v0 + v3;
    v1 = ((v1 << 17) | (v1 >> 47));  // rotate_left(17)
    v3 = ((v3 << 21) | (v3 >> 43));  // rotate_left(21)
    v1 = v1 ^ v2;  v3 = v3 ^ v0;
    v2 = ((v2 << 32) | (v2 >> 32));  // rotate_left(32)

    // --- Compression Round 2 ---
    v0 = v0 + v1;  v2 = v2 + v3;
    v1 = ((v1 << 13) | (v1 >> 51));
    v3 = ((v3 << 16) | (v3 >> 48));
    v1 = v1 ^ v0;  v3 = v3 ^ v2;
    v0 = ((v0 << 32) | (v0 >> 32));
    v2 = v2 + v1;  v0 = v0 + v3;
    v1 = ((v1 << 17) | (v1 >> 47));
    v3 = ((v3 << 21) | (v3 >> 43));
    v1 = v1 ^ v2;  v3 = v3 ^ v0;
    v2 = ((v2 << 32) | (v2 >> 32));

    v0 = v0 ^ m;

    // Finalization
    v2 = v2 ^ 0xFF;

    // --- Finalization Round 1 ---
    v0 = v0 + v1;  v2 = v2 + v3;
    v1 = ((v1 << 13) | (v1 >> 51));
    v3 = ((v3 << 16) | (v3 >> 48));
    v1 = v1 ^ v0;  v3 = v3 ^ v2;
    v0 = ((v0 << 32) | (v0 >> 32));
    v2 = v2 + v1;  v0 = v0 + v3;
    v1 = ((v1 << 17) | (v1 >> 47));
    v3 = ((v3 << 21) | (v3 >> 43));
    v1 = v1 ^ v2;  v3 = v3 ^ v0;
    v2 = ((v2 << 32) | (v2 >> 32));

    // --- Finalization Round 2 ---
    v0 = v0 + v1;  v2 = v2 + v3;
    v1 = ((v1 << 13) | (v1 >> 51));
    v3 = ((v3 << 16) | (v3 >> 48));
    v1 = v1 ^ v0;  v3 = v3 ^ v2;
    v0 = ((v0 << 32) | (v0 >> 32));
    v2 = v2 + v1;  v0 = v0 + v3;
    v1 = ((v1 << 17) | (v1 >> 47));
    v3 = ((v3 << 21) | (v3 >> 43));
    v1 = v1 ^ v2;  v3 = v3 ^ v0;
    v2 = ((v2 << 32) | (v2 >> 32));

    // --- Finalization Round 3 ---
    v0 = v0 + v1;  v2 = v2 + v3;
    v1 = ((v1 << 13) | (v1 >> 51));
    v3 = ((v3 << 16) | (v3 >> 48));
    v1 = v1 ^ v0;  v3 = v3 ^ v2;
    v0 = ((v0 << 32) | (v0 >> 32));
    v2 = v2 + v1;  v0 = v0 + v3;
    v1 = ((v1 << 17) | (v1 >> 47));
    v3 = ((v3 << 21) | (v3 >> 43));
    v1 = v1 ^ v2;  v3 = v3 ^ v0;
    v2 = ((v2 << 32) | (v2 >> 32));

    // --- Finalization Round 4 ---
    v0 = v0 + v1;  v2 = v2 + v3;
    v1 = ((v1 << 13) | (v1 >> 51));
    v3 = ((v3 << 16) | (v3 >> 48));
    v1 = v1 ^ v0;  v3 = v3 ^ v2;
    v0 = ((v0 << 32) | (v0 >> 32));
    v2 = v2 + v1;  v0 = v0 + v3;
    v1 = ((v1 << 17) | (v1 >> 47));
    v3 = ((v3 << 21) | (v3 >> 43));
    v1 = v1 ^ v2;  v3 = v3 ^ v0;
    v2 = ((v2 << 32) | (v2 >> 32));

    return v0 ^ v1 ^ v2 ^ v3;
}

// =============================================================================
// hash_combine — Cascaded SipHash-2-4 for proof-hint generation
// =============================================================================
// This MUST produce identical output to the Rust compiler's hash_combine().
// Algorithm: hash(struct_id) → hash(result ⊕ offset) → hash(result ⊕ align)
// =============================================================================

pub fn hash_combine(struct_id: u64, offset: u64, align: u64) -> u64 {
    let h1 = siphash24(SIPHASH_K0, SIPHASH_K1, struct_id);
    let h2 = siphash24(SIPHASH_K0, SIPHASH_K1, h1 ^ offset);
    let h3 = siphash24(SIPHASH_K0, SIPHASH_K1, h2 ^ align);
    return h3;
}

// =============================================================================
// struct_name_to_id — Pack struct name into u64 and hash via SipHash-2-4
// =============================================================================
// For SpscRing, pre-computes the XOR-folded byte packing.
// This avoids string processing at runtime.
// =============================================================================

pub fn struct_name_to_id_spsc() -> u64 {
    // "SpscRing" = bytes [0x53, 0x70, 0x73, 0x63, 0x52, 0x69, 0x6E, 0x67]
    // XOR-fold into u64 (little-endian byte packing):
    //   packed = 0x53 | (0x70 << 8) | (0x73 << 16) | (0x63 << 24)
    //          | (0x52 << 32) | (0x69 << 40) | (0x6E << 48) | (0x67 << 56)
    let packed: u64 = 0x676E695263737053;
    return siphash24(SIPHASH_K0, SIPHASH_K1, packed);
}

// =============================================================================
// validate_descriptor_fast — O(1) Arbiter Fast Path
// =============================================================================
// Hot-path function called on every SPSC ring access.
// Target: < 12 CPU cycles.
//
// Returns 1 (valid) or 0 (SecurityViolation).
// =============================================================================

pub fn validate_descriptor_fast(desc_ptr: u64, desc_proof_hint: u64, authorized_hint: u64) -> u64 {
    // Gate 1: Mechanical alignment check (64-byte cache line)
    // Catches Vector A: Alignment Subversion
    if (desc_ptr & 0x3F) != 0 {
        return 0;
    }

    // Gate 2: Proof-hint bitwise comparison (constant-time)
    // Catches Vector B: Hint Forgery
    if desc_proof_hint != authorized_hint {
        return 0;
    }

    return 1;
}

// =============================================================================
// validate_ring_bounds — Clamp untrusted Ring 3 ring metadata
// =============================================================================
// Directive 3.1 (SPSC Hardening): Untrusted userspace writes capacity and tail
// into shared memory rings. Malicious values can cause wrap-around OOB reads.
// This function sanitizes ring indices before the kernel or NetD uses them.
//
// Clamping rules:
//   capacity: clamped to [1, PAGE_SIZE - RING_HEADER_SIZE]
//   tail:     clamped to [0, capacity - 1]
//   head:     clamped to [0, capacity - 1]
// =============================================================================

const RING_HEADER_SIZE: u64 = 192;    // 3 cache lines × 64 bytes
const MAX_RING_DATA_SIZE: u64 = 4096 - RING_HEADER_SIZE;  // 3904 bytes
const MIN_CAPACITY: u64 = 1;
const MAX_CAPACITY: u64 = MAX_RING_DATA_SIZE;

/// Clamp an untrusted capacity value to safe bounds.
/// Returns the sanitized capacity (guaranteed: 1 <= result <= MAX_CAPACITY).
pub fn clamp_capacity(raw_capacity: u64) -> u64 {
    if raw_capacity < MIN_CAPACITY {
        return MIN_CAPACITY;
    }
    if raw_capacity > MAX_CAPACITY {
        return MAX_CAPACITY;
    }
    return raw_capacity;
}

/// Clamp an untrusted ring index (head or tail) to [0, capacity-1].
/// Returns the sanitized index. Guards against wrap-around OOB.
pub fn clamp_ring_index(raw_index: u64, capacity: u64) -> u64 {
    // capacity is already sanitized by clamp_capacity, so capacity >= 1
    if raw_index >= capacity {
        return capacity - 1;  // clamp to last valid index
    }
    return raw_index;
}

/// Validate all untrusted ring metadata in one call.
/// Returns 1 if the descriptor passes all checks (alignment + proof + bounds),
/// and the sanitized values are written to the output pointers.
/// Returns 0 if any check fails.
pub fn validate_descriptor_full(
    desc_ptr: u64,
    desc_proof_hint: u64,
    authorized_hint: u64,
    raw_capacity: u64,
    raw_tail: u64,
    raw_head: u64,
    out_capacity: Ptr<u64>,
    out_tail: Ptr<u64>,
    out_head: Ptr<u64>,
) -> u64 {
    // Gate 1: Alignment (64-byte cache line)
    if (desc_ptr & 0x3F) != 0 { return 0; }

    // Gate 2: Proof hint (cryptographic integrity)
    if desc_proof_hint != authorized_hint { return 0; }

    // Gate 3: Bounds clamping (prevents OOB from untrusted userspace)
    let cap = clamp_capacity(raw_capacity);
    let tail = clamp_ring_index(raw_tail, cap);
    let head = clamp_ring_index(raw_head, cap);

    out_capacity.write(cap);
    out_tail.write(tail);
    out_head.write(head);

    return 1;
}

// =============================================================================
// Pre-computed authorized hints for SpscRing fields
// =============================================================================
// Called once during NetD initialization. Results are cached core-locally.
// =============================================================================

pub fn generate_authorized_hint_head() -> u64 {
    let struct_id = struct_name_to_id_spsc();
    return hash_combine(struct_id, 0, 64);  // head is at offset 0, align 64
}

pub fn generate_authorized_hint_tail() -> u64 {
    let struct_id = struct_name_to_id_spsc();
    return hash_combine(struct_id, 64, 64); // tail is at offset 64, align 64
}
