// =============================================================================
// DataBlobSparseSet — persistent data blobs (Tier 2.2)
// =============================================================================
import kernel.ecs.components.{DataBlob}

pub struct DataBlobSparseSet {
    pub dense: Ptr<DataBlob>,
    pub sparse: Ptr<u32>,
    pub entity_map: Ptr<Entity>,
    pub count: u32,
}

pub fn datablob_set_insert(set: Ptr<DataBlobSparseSet>, entity: Entity, component: DataBlob) {
    let id = entity.id;
    if id >= MAX_ENTITIES { return; }
    let s_ptr = set[0].sparse;
    let dense_idx = (*(( (s_ptr as u64) + (id as u64) * 4 ) as &u32));
    if dense_idx != 0xFFFFFFFF {
        (*(( (set[0].dense as u64) + (dense_idx as u64) * (size_of::<DataBlob>() as u64) ) as &mut DataBlob)) = component;
        (*(( (set[0].entity_map as u64) + (dense_idx as u64) * 8 ) as &mut Entity)) = entity;
        return;
    }
    let count = set[0].count;
    if count >= MAX_ENTITIES { return; }
    (*(( (set[0].dense as u64) + (count as u64) * (size_of::<DataBlob>() as u64) ) as &mut DataBlob)) = component;
    (*(( (set[0].entity_map as u64) + (count as u64) * 8 ) as &mut Entity)) = entity;
    (*(( (set[0].sparse as u64) + (id as u64) * 4 ) as &mut u32)) = count;
    set[0].count = count + 1;
}

pub fn datablob_set_get(set: Ptr<DataBlobSparseSet>, entity: Entity) -> Ptr<DataBlob> {
    let sid = entity.id;
    if sid >= MAX_ENTITIES { return 0 as Ptr<DataBlob>; }
    let dense_idx = (*(( (set[0].sparse as u64) + (sid as u64) * 4 ) as &u32));
    if dense_idx != 0xFFFFFFFF {
        if (*(( (set[0].entity_map as u64) + (dense_idx as u64) * 8 ) as &Entity)).gen == entity.gen {
            return ((set[0].dense as u64) + (dense_idx as u64) * (size_of::<DataBlob>() as u64)) as Ptr<DataBlob>;
        }
    }
    return 0 as Ptr<DataBlob>;
}

pub fn new_datablob_set() -> Ptr<DataBlobSparseSet> {
    let t_size = size_of::<DataBlob>();
    let d_ptr = malloc((MAX_ENTITIES as i64) * t_size) as Ptr<DataBlob>;
    let s_ptr = malloc((MAX_ENTITIES as i64) * 4) as Ptr<u32>;
    let e_ptr = malloc((MAX_ENTITIES as i64) * 8) as Ptr<Entity>;
    let mut i: u32 = 0;
    while i < MAX_ENTITIES {
        (*(( (s_ptr as u64) + (i as u64) * 4 ) as &mut u32)) = 0xFFFFFFFF;
        i = i + 1;
    }
    let p = malloc(size_of::<DataBlobSparseSet>() as i64) as Ptr<DataBlobSparseSet>;
    p[0] = DataBlobSparseSet { dense: d_ptr, sparse: s_ptr, entity_map: e_ptr, count: 0 };
    return p;
}

pub fn datablob_set_remove(set: Ptr<DataBlobSparseSet>, entity: Entity) {
    let sid = entity.id;
    if sid >= MAX_ENTITIES { return; }
    let dense_idx = (*(( (set[0].sparse as u64) + (sid as u64) * 4 ) as &u32));
    if dense_idx != 0xFFFFFFFF {
        if (*(( (set[0].entity_map as u64) + (dense_idx as u64) * 8 ) as &Entity)).gen == entity.gen {
            let last_idx = set[0].count - 1;
            if dense_idx != last_idx {
                (*(( (set[0].dense as u64) + (dense_idx as u64) * (size_of::<DataBlob>() as u64) ) as &mut DataBlob)) = (*(( (set[0].dense as u64) + (last_idx as u64) * (size_of::<DataBlob>() as u64) ) as &DataBlob));
                let last_entity = (*(( (set[0].entity_map as u64) + (last_idx as u64) * 8 ) as &Entity));
                (*(( (set[0].entity_map as u64) + (dense_idx as u64) * 8 ) as &mut Entity)) = last_entity;
                (*(( (set[0].sparse as u64) + (last_entity.id as u64) * 4 ) as &mut u32)) = dense_idx;
            }
            (*(( (set[0].sparse as u64) + (sid as u64) * 4 ) as &mut u32)) = 0xFFFFFFFF;
            set[0].count = last_idx;
        }
    }
}

// =============================================================================
// Delegation wrappers — NameSparseSet (impl in name_set.salt)
// =============================================================================
pub fn new_name_set() -> Ptr<NameSparseSet> {
    return new_name_set();
}
pub fn name_set_insert(set: Ptr<NameSparseSet>, entity: Entity, component: NameComponent) {
    name_set_insert(set, entity, component);
}
pub fn name_set_get(set: Ptr<NameSparseSet>, entity: Entity) -> Ptr<NameComponent> {
    return name_set_get(set, entity);
}
pub fn name_set_remove(set: Ptr<NameSparseSet>, entity: Entity) {
    name_set_remove(set, entity);
}
