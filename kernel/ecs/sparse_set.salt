// =============================================================================
// kernel/ecs/sparse_set.salt
// ECS sparse-set storage: MemMap, IpcCap, Socket, and TestComponent sets.
// Scheduling-related sets (thread, priority, affinity, epoch, perf counters)
// live in scheduling_sets.salt — this file provides delegation wrappers so
// existing callers don't need to change their imports.
// =============================================================================

package kernel.ecs.sparse_set

import kernel.ecs.entity.{Entity, MAX_ENTITIES}
import std.core.mem.size_of
import kernel.ecs.components.{MemoryMap, IpcCapability, OpenSocket, TestComponent, NameComponent}
import kernel.ecs.name_set.{NameSparseSet, new_name_set, name_set_insert, name_set_get, name_set_remove}
import kernel.ecs.scheduling_sets.{ThreadSparseSet, new_thread_set, thread_set_insert, thread_set_get_mut, thread_set_remove, PrioritySparseSet, new_priority_set, priority_set_insert, priority_set_get, priority_set_remove, AffinitySparseSet, new_affinity_set, affinity_set_insert, affinity_set_get, affinity_set_remove, EpochInfoSparseSet, new_epoch_info_set, epoch_info_set_insert, epoch_info_set_get, epoch_info_set_remove, PerfCountersSparseSet, new_perf_counters_set, perf_counters_set_insert, perf_counters_set_get, perf_counters_set_remove}

extern fn malloc(size: i64) -> Ptr<u8>;

// =============================================================================
// Delegation wrappers — ThreadSparseSet (impl in scheduling_sets.salt)
// =============================================================================
pub fn new_thread_set() -> Ptr<ThreadSparseSet> {
    return new_thread_set();
}
pub fn thread_set_insert(set: Ptr<ThreadSparseSet>, entity: Entity, component: ThreadState) {
    thread_set_insert(set, entity, component);
}
pub fn thread_set_get_mut(set: Ptr<ThreadSparseSet>, entity: Entity) -> Ptr<ThreadState> {
    return thread_set_get_mut(set, entity);
}
pub fn thread_set_remove(set: Ptr<ThreadSparseSet>, entity: Entity) {
    thread_set_remove(set, entity);
}

