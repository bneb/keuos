// 4. ProcessExitEvent Queue
pub struct ProcessExitEvent {
    pub entity: Entity,
    pub exit_code: i32,
}
 
pub struct ProcessExitEvents {
    pub queue: Ptr<ProcessExitEvent>,
    pub head: i64,
    pub tail: i64,
}
 
pub global PROCESS_EXIT_EVENTS: Ptr<ProcessExitEvents> = 0 as Ptr<ProcessExitEvents>;
 
pub fn new_process_exit_events() -> Ptr<ProcessExitEvents> {
    let q_ptr = malloc(256 * size_of::<ProcessExitEvent>()) as Ptr<ProcessExitEvent>;
    let p = malloc(24) as Ptr<ProcessExitEvents>;
    p[0] = ProcessExitEvents {
        queue: q_ptr,
        head: 0,
        tail: 0,
    };
    return p;
}
 
pub fn process_exit_events_push(self: Ptr<ProcessExitEvents>, ev: ProcessExitEvent) {
    let head_addr = (&self[0].head) as u64;
    let tail_addr = (&self[0].tail) as u64;
    
    let curr_head = volatile_read_i64(head_addr);
    let curr_tail = volatile_read_i64(tail_addr);
    
    let next_head = (curr_head + 1) % 256;
    if next_head != curr_tail {
        unsafe {
            let slot = (self[0].queue.offset(curr_head as i64)) as &mut ProcessExitEvent;
            *slot = ev;
        }
        volatile_write_i64(head_addr, next_head);
    }
}
 
pub fn process_exit_events_pop(self: Ptr<ProcessExitEvents>, out: Ptr<ProcessExitEvent>) -> bool {
    let head_addr = (&self[0].head) as u64;
    let tail_addr = (&self[0].tail) as u64;
    
    let curr_head = volatile_read_i64(head_addr);
    let curr_tail = volatile_read_i64(tail_addr);
    
    if curr_head == curr_tail { return false; }
    
    unsafe {
        let slot = (self[0].queue.offset(curr_tail as i64)) as &ProcessExitEvent;
        let out_ref = out as &mut ProcessExitEvent;
        *out_ref = *slot;
    }
    volatile_write_i64(tail_addr, (curr_tail + 1) % 256);
    return true;
}
 
pub fn ecs_events_init() {
    NETWORK_EVENTS = new_network_events();
    TIMER_EVENTS = new_timer_events();
    PROCESS_EXIT_EVENTS = new_process_exit_events();
}
