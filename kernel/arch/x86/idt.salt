package kernel.arch.x86.idt
// Interrupt Descriptor Table for x86_64 Long Mode.
import kernel.core.io
import kernel.drivers.virtio_net
extern fn outb(port: u16, val: u8);

struct IDTEntry {
    offset_low: u16,    // bits 0..15
    selector: u16,      // code segment selector
    ist: u8,            // IST index/reserved
    type_attr: u8,      // type and attributes
    offset_middle: u16, // bits 16..31
    offset_high: u32,   // bits 32..63
    reserved: u32       // reserved
}

struct IDTPointer {
    limit: u16,
    base: u64
}

const IDT_BASE_VIRTUAL: u64 = 0xFFFFFFFF80000000; // Example base

global GLOBAL_IDT: [IDTEntry; 256] = [IDTEntry {
    offset_low: 0,
    selector: 0,
    ist: 0,
    type_attr: 0,
    offset_middle: 0,
    offset_high: 0,
    reserved: 0
}; 256];

pub fn register_gate(vector: u8, handler: u64) {
    // 64-bit IDT entries are 16 bytes each
    // Directly modify the global IDT array
    GLOBAL_IDT[vector as i32].offset_low = (handler & 0xFFFF) as u16;
    GLOBAL_IDT[vector as i32].offset_middle = ((handler >> 16) & 0xFFFF) as u16;
    GLOBAL_IDT[vector as i32].offset_high = ((handler >> 32) & 0xFFFFFFFF) as u32;
    GLOBAL_IDT[vector as i32].selector = 0x08; // Kernel Code Segment
    GLOBAL_IDT[vector as i32].type_attr = 0x8E; // Present, Ring 0, Interrupt Gate
    GLOBAL_IDT[vector as i32].ist = 0;
    GLOBAL_IDT[vector as i32].reserved = 0;
}

// =============================================================================
// register_gate_ist — Register an IDT gate with an IST index
// =============================================================================
// Same as register_gate but sets the IST field so the CPU uses a dedicated
// stack from the TSS for this exception vector. Critical for:
//   IST 1 → NMI (vector 0x02)   — non-maskable, can fire during CLI
//   IST 2 → #DF (vector 0x08)   — double fault needs known-good stack
// =============================================================================
pub fn register_gate_ist(vector: u8, handler: u64, ist_index: u8) {
    register_gate(vector, handler);
    GLOBAL_IDT[vector as i32].ist = ist_index;
}

@no_mangle
extern fn timer_isr_wrapper();

@no_mangle
extern fn syscall_entry();

@no_mangle
extern fn tlb_shootdown_wrapper();

@no_mangle
extern fn virtio_isr_wrapper();

@no_mangle
extern fn serial_isr_wrapper();

@no_mangle
extern fn ps2_isr_wrapper();

// NMI and Double Fault handlers (IST-based)
@no_mangle
extern fn nmi_isr_wrapper();

@no_mangle
extern fn df_isr_wrapper();

fn pic_remap(offset1: u8, offset2: u8) {
    region("pic_remap") {
        let ICW1_ICW4: u8      = 0x01; // ICW4 (not) needed
        let ICW1_SINGLE: u8    = 0x02; // Single (cascade) mode
        let ICW1_INTERVAL4: u8 = 0x04; // Call address interval 4 (8)
        let ICW1_LEVEL: u8     = 0x08; // Level triggered (edge) mode
        let ICW1_INIT: u8      = 0x10; // Initialization - required!
        
        let PIC1: u16 = 0x20;
        let PIC2: u16 = 0xA0;
        let PIC1_COMMAND: u16 = PIC1;
        let PIC1_DATA: u16 = PIC1 + 1;
        let PIC2_COMMAND: u16 = PIC2;
        let PIC2_DATA: u16 = PIC2 + 1;

        // Initialization
        outb(PIC1_COMMAND, ICW1_INIT | ICW1_ICW4);
        outb(PIC2_COMMAND, ICW1_INIT | ICW1_ICW4);
        
        // Vector offsets
        outb(PIC1_DATA, offset1);
        outb(PIC2_DATA, offset2);
        
        // Cascading
        outb(PIC1_DATA, 4);
        outb(PIC2_DATA, 2);
        
        // ICW4
        outb(PIC1_DATA, 0x01); // 8086 mode
        outb(PIC2_DATA, 0x01);
        
        // Unmask All
        outb(PIC1_DATA, 0);
        outb(PIC2_DATA, 0);
    }
}

extern fn lidt_wrapper(limit: u16, base: u64);

@no_mangle
extern fn nm_isr_wrapper();

pub fn init() {
    region idt_init(0x0000, 0) {
        pic_remap(0x20, 0x28);

        // 0x07: #NM (Device Not Available) — Lazy FPU switching
        let nm_handler = (&nm_isr_wrapper) as u64;
        register_gate(0x07, nm_handler);

        // 0x8E: 32-bit Interrupt Gate, Present, Ring 0
        // 0x20: PIT IRQ0 (Master PIC offset)
        let handler = (&timer_isr_wrapper) as u64;
        register_gate(0x20, handler);
        
        // 0x80: Syscall interrupt gate (Ring 0, Present)
        let syscall_handler = (&syscall_entry) as u64;
        register_gate(0x80, syscall_handler);

        // 0x21: PS/2 Keyboard IRQ (IRQ1 = PIC offset 0x20 + 1)
        let ps2_handler = (&ps2_isr_wrapper) as u64;
        register_gate(0x21, ps2_handler);

        // 0x2B: VirtIO-Net IRQ (IRQ11 = PIC offset 0x20 + 11)
        let virtio_handler = (&virtio_isr_wrapper) as u64;
        register_gate(0x2B, virtio_handler);
        
        // 0x24: COM1 Serial IRQ (IRQ4 = PIC offset 0x20 + 4)
        let serial_handler = (&serial_isr_wrapper) as u64;
        register_gate(0x24, serial_handler);
        
        // 0xFD: TLB Shootdown IPI
        let shootdown_handler = (&tlb_shootdown_wrapper) as u64;
        register_gate(0xFD, shootdown_handler);
        
        let limit = (256 * 16 - 1) as u16;
        let base = (&GLOBAL_IDT) as u64;
        
        // Load IDT with packed wrapper
        lidt_wrapper(limit, base);
    }
}

// =============================================================================
// init_ist_gates — Phase 2 IDT init: wire IST-based exception handlers
// =============================================================================
// MUST be called AFTER:
//   1. PMM init (IST stacks need physical pages)
//   2. tss_set_ist() (TSS must know the IST stack addresses)
//   3. idt.init() (base IDT + LIDT already loaded)
//
// Updates the live IDT in-place. Since LIDT was already called, the CPU
// picks up the new entries immediately — no need to reload.
// =============================================================================
pub fn init_ist_gates() {
    // Vector 0x02: NMI — Non-Maskable Interrupt
    // Uses IST 1 so NMI always lands on a known-good stack,
    // even if it fires during CLI or mid-SWAPGS.
    let nmi_handler = (&nmi_isr_wrapper) as u64;
    register_gate_ist(0x02, nmi_handler, 1);

    // Vector 0x08: #DF — Double Fault
    // Uses IST 2 so #DF can fire even when the current stack is exhausted.
    // This prevents the triple-fault → reboot cascade.
    let df_handler = (&df_isr_wrapper) as u64;
    register_gate_ist(0x08, df_handler, 2);
}

// @no_mangle ABI Wrappers
@no_mangle
pub fn idt_init() { init(); }

@no_mangle
pub fn idt_init_ist_gates() { init_ist_gates(); }

@no_mangle
pub fn get_idt_base() -> u64 { return (&GLOBAL_IDT) as u64; }
