// =============================================================================
// kernel/arch/x86/gdt.salt
// Global Descriptor Table -- 8-Entry Ring 3 Configuration (SYSRET-Compatible)
// =============================================================================
//
// The GDT layout is specifically ordered for x86_64 SYSRET compatibility.
// SYSRET computes selectors from STAR MSR[63:48] as:
//   SS        = STAR[63:48] + 8  | RPL=3
//   CS (64b)  = STAR[63:48] + 16 | RPL=3
//
// With STAR[63:48] = 0x18 (pointing at User Code 32 placeholder):
//   SS  = 0x18 + 8  | 3 = 0x23 → GDT[4] = User Data (DPL 3) ✓
//   CS  = 0x18 + 16 | 3 = 0x2B → GDT[5] = User Code 64 (DPL 3) ✓
//
// 8-Entry Layout:
//   Index 0 (0x00): Null Descriptor
//   Index 1 (0x08): Kernel Code 64 (DPL 0)
//   Index 2 (0x10): Kernel Data 64 (DPL 0)
//   Index 3 (0x18): User Code 32 (DPL 3)  -- SYSRET base (unused for 64-bit)
//   Index 4 (0x20): User Data 64 (DPL 3)  -- SYSRET SS = 0x23
//   Index 5 (0x28): User Code 64 (DPL 3)  -- SYSRET CS = 0x2B
//   Index 6 (0x30): TSS Descriptor Low     -- 16-byte TSS descriptor
//   Index 7 (0x38): TSS Descriptor High
// =============================================================================

package kernel.arch.x86.gdt

// =============================================================================
// GDT Entry -- 8 bytes, matches x86 descriptor layout
// =============================================================================
pub struct GdtEntry {
    limit_low: u16,
    base_low: u16,
    base_mid: u8,
    access: u8,
    granularity: u8,
    base_high: u8,
}

// =============================================================================
// GDT Pointer -- for LGDT instruction
// =============================================================================
pub struct GdtPtr {
    limit: u16,    // Size of GDT - 1
    base: u64,     // Virtual address of GDT
}

// =============================================================================
// Access Byte Constants
// =============================================================================
const ACCESS_KERNEL_CODE: u8 = 0x9A;  // P=1, DPL=0, S=1, Type=0xA
const ACCESS_KERNEL_DATA: u8 = 0x92;  // P=1, DPL=0, S=1, Type=0x2
const ACCESS_USER_CODE: u8   = 0xFA;  // P=1, DPL=3, S=1, Type=0xA
const ACCESS_USER_DATA: u8   = 0xF2;  // P=1, DPL=3, S=1, Type=0x2
const ACCESS_TSS: u8         = 0x89;  // P=1, DPL=0, S=0, Type=0x9

// =============================================================================
// Granularity / Flags Byte Constants
// =============================================================================
const GRAN_CODE64: u8 = 0xAF;   // G=1, L=1, limit_high=0xF (64-bit code)
const GRAN_CODE32: u8 = 0xCF;   // G=1, D=1, limit_high=0xF (32-bit code)
const GRAN_DATA64: u8 = 0xCF;   // G=1, D=1, limit_high=0xF (64-bit data)

// =============================================================================
// Selectors -- SYSRET-compatible ordering
// =============================================================================
pub const SEL_NULL: u16        = 0x00;
pub const SEL_KERNEL_CODE: u16 = 0x08;
pub const SEL_KERNEL_DATA: u16 = 0x10;
pub const SEL_USER_CODE32: u16 = 0x1B;  // 0x18 | RPL 3 (SYSRET base)
pub const SEL_USER_DATA: u16   = 0x23;  // 0x20 | RPL 3 (SYSRET SS)
pub const SEL_USER_CODE: u16   = 0x2B;  // 0x28 | RPL 3 (SYSRET CS64)
pub const SEL_TSS: u16         = 0x30;

// =============================================================================
// Static 8-entry GDT
// =============================================================================
global GDT_ENTRIES: [GdtEntry; 8];

// =============================================================================
// init -- Basic 3-entry GDT for early boot
// =============================================================================
pub fn init() {
    GDT_ENTRIES[0] = GdtEntry(0, 0, 0, 0, 0, 0);

    let mut kcode = GdtEntry(0, 0, 0, 0, 0, 0);
    kcode.limit_low = 0xFFFF;
    kcode.access = ACCESS_KERNEL_CODE;
    kcode.granularity = GRAN_CODE64;
    GDT_ENTRIES[1] = kcode;

    let mut kdata = GdtEntry(0, 0, 0, 0, 0, 0);
    kdata.limit_low = 0xFFFF;
    kdata.access = ACCESS_KERNEL_DATA;
    kdata.granularity = GRAN_DATA64;
    GDT_ENTRIES[2] = kdata;

    GDT_ENTRIES[3] = GdtEntry(0, 0, 0, 0, 0, 0);
    GDT_ENTRIES[4] = GdtEntry(0, 0, 0, 0, 0, 0);
    GDT_ENTRIES[5] = GdtEntry(0, 0, 0, 0, 0, 0);
    GDT_ENTRIES[6] = GdtEntry(0, 0, 0, 0, 0, 0);
    GDT_ENTRIES[7] = GdtEntry(0, 0, 0, 0, 0, 0);
}

// =============================================================================
// init_ring3 -- Full 8-entry GDT with Ring 3 + TSS (SYSRET-compatible)
// =============================================================================
pub fn init_ring3(tss_addr: u64) {
    // Index 0: Null
    GDT_ENTRIES[0] = GdtEntry(0, 0, 0, 0, 0, 0);

    // Index 1 (0x08): Kernel Code 64
    let mut kcode = GdtEntry(0, 0, 0, 0, 0, 0);
    kcode.limit_low = 0xFFFF;
    kcode.access = ACCESS_KERNEL_CODE;
    kcode.granularity = GRAN_CODE64;
    GDT_ENTRIES[1] = kcode;

    // Index 2 (0x10): Kernel Data 64
    let mut kdata = GdtEntry(0, 0, 0, 0, 0, 0);
    kdata.limit_low = 0xFFFF;
    kdata.access = ACCESS_KERNEL_DATA;
    kdata.granularity = GRAN_DATA64;
    GDT_ENTRIES[2] = kdata;

    // Index 3 (0x18): User Code 32 (DPL 3) -- SYSRET base (compat mode stub)
    let mut ucode32 = GdtEntry(0, 0, 0, 0, 0, 0);
    ucode32.limit_low = 0xFFFF;
    ucode32.access = ACCESS_USER_CODE;
    ucode32.granularity = GRAN_CODE32;
    GDT_ENTRIES[3] = ucode32;

    // Index 4 (0x20): User Data 64 (DPL 3) -- selector 0x23
    let mut udata = GdtEntry(0, 0, 0, 0, 0, 0);
    udata.limit_low = 0xFFFF;
    udata.access = ACCESS_USER_DATA;
    udata.granularity = GRAN_DATA64;
    GDT_ENTRIES[4] = udata;

    // Index 5 (0x28): User Code 64 (DPL 3) -- selector 0x2B
    let mut ucode64 = GdtEntry(0, 0, 0, 0, 0, 0);
    ucode64.limit_low = 0xFFFF;
    ucode64.access = ACCESS_USER_CODE;
    ucode64.granularity = GRAN_CODE64;
    GDT_ENTRIES[5] = ucode64;

    // Index 6-7 (0x30-0x38): TSS Descriptor (16 bytes = 2 GDT slots)
    let tss_limit: u16 = 103;
    let tss_base_low: u16 = (tss_addr & 0xFFFF) as u16;
    let tss_base_mid: u8 = ((tss_addr >> 16) & 0xFF) as u8;
    let tss_base_high: u8 = ((tss_addr >> 24) & 0xFF) as u8;
    let tss_base_upper: u32 = ((tss_addr >> 32) & 0xFFFFFFFF) as u32;

    let mut tss_lo = GdtEntry(0, 0, 0, 0, 0, 0);
    tss_lo.limit_low = tss_limit;
    tss_lo.base_low = tss_base_low;
    tss_lo.base_mid = tss_base_mid;
    tss_lo.access = ACCESS_TSS;
    tss_lo.granularity = 0;
    tss_lo.base_high = tss_base_high;
    GDT_ENTRIES[6] = tss_lo;

    let mut tss_hi = GdtEntry(0, 0, 0, 0, 0, 0);
    tss_hi.limit_low = (tss_base_upper & 0xFFFF) as u16;
    tss_hi.base_low = ((tss_base_upper >> 16) & 0xFFFF) as u16;
    GDT_ENTRIES[7] = tss_hi;
}

extern fn lgdt_wrapper(limit: u16, base: u64);
extern fn ltr_wrapper(selector: u16);

// @no_mangle ABI Wrappers
@no_mangle
pub fn gdt_init() { init(); }

@no_mangle
pub fn gdt_init_ring3(tss_addr: u64) { init_ring3(tss_addr); }

@no_mangle
pub fn gdt_load_ring3() {
    lgdt_wrapper(63, (&GDT_ENTRIES) as u64);
    ltr_wrapper(0x30);
}

@no_mangle
pub fn get_gdt_base() -> u64 {
    return (&GDT_ENTRIES) as u64;
}
