package kernel.tests.nvme_test

import std.core.ptr.Ptr
import kernel.keuos.hw.pcie_enum
import kernel.drivers.serial
import kernel.drivers.nvme
import kernel.drivers.nvme.SqEntry
import kernel.drivers.nvme.NvmeController

extern fn outb(port: u16, val: u8);

pub fn qemu_exit(code: u8) {
    // ISA debug exit
    unsafe {
        outb(0xf4, code);
    }
}

pub fn kmain(magic: u32, info: Ptr<u8>) {
    serial.init();
    serial.print("==================================\n");
    serial.print(" NVMe Test Kernel Booted \n");
    serial.print("==================================\n");

    let ecam_base: Ptr<u32> = 0xB0000000 as Ptr<u32>;
    
    // QEMU NVMe: Vendor = 0x1B36, Device = 0x0010
    serial.print("Scanning PCIe bus for NVMe controller...\n");
    let res = pcie_enum.discover_device_bar(ecam_base, 0x1B36, 0x0010, 2);

    if res.physical_address != 0 {
        serial.print("NVMe Controller Found!\n");
        serial.print("  Bus:  "); serial.print_u64(res.bus as u64); serial.print("\n");
        serial.print("  Dev:  "); serial.print_u64(res.device as u64); serial.print("\n");
        serial.print("  BAR0: "); serial.print_hex(res.physical_address); serial.print("\n");

        let nvme_bar: Ptr<u32> = res.physical_address as Ptr<u32>;
        
        // Read CAP (Capabilities) - 64-bit at offset 0x00
        let cap_low: u32 = nvme_bar.offset(0).read();
        let cap_high: u32 = nvme_bar.offset(1).read();
        let cap: u64 = ((cap_high as u64) << 32) | (cap_low as u64);
        
        // Read VS (Version) - 32-bit at offset 0x08
        let vs: u32 = nvme_bar.offset(2).read();

        serial.print("  CAP:  "); serial.print_hex(cap); serial.print("\n");
        serial.print("  VS:   "); serial.print_hex(vs as u64); serial.print("\n");

        // Identity-mapped memory block for the Queues (above kernel, e.g. at 32MB)
        let asq_phys: u64 = 0x2000000;
        let acq_phys: u64 = 0x2001000;
        
        // Clear the memory
        nvme.zero_memory(asq_phys as Ptr<u8>, 4096);
        nvme.zero_memory(acq_phys as Ptr<u8>, 4096);

        // Initialize Admin Queues
        let mut ctrl = nvme.init(res.physical_address, asq_phys, acq_phys);

        serial.print("Sending Identify Controller command...\n");
        let id_cmd_ptr = 0x2002000 as Ptr<u32>;
        let id_buf_phys: u64 = 0x2003000;
        
        nvme.zero_memory(id_cmd_ptr as Ptr<u8>, 64);
        nvme.zero_memory(id_buf_phys as Ptr<u8>, 4096);

        id_cmd_ptr.offset(0).write(0x06); // cdw0: Opcode 0x06 Identify
        id_cmd_ptr.offset(1).write(0);    // nsid
        id_cmd_ptr.offset(6).write((id_buf_phys & 0xFFFFFFFF) as u32); // dptr_prp1 low
        id_cmd_ptr.offset(7).write((id_buf_phys >> 32) as u32);        // dptr_prp1 high
        id_cmd_ptr.offset(10).write(1); // cdw10: CNS = 1 (Identify Controller)

        let ctrl_ptr = (&ctrl) as Ptr<NvmeController>;
        
        serial.print("  CTRL BAR BEFORE SUBMIT: ");
        serial.print_hex(ctrl_ptr.offset(0).read().bar as u64);
        serial.print("\n");
        
        nvme.submit_admin_cmd(ctrl_ptr, id_cmd_ptr as Ptr<SqEntry>);

        let status = nvme.poll_admin_cq(ctrl_ptr);
        serial.print("Identify Command Complete. Status: ");
        serial.print_hex(status as u64);
        serial.print("\n");

        // The Model Number is at offset 24 in the Identify Controller data structure, 40 bytes ASCII
        serial.print("NVMe Model Number: ");
        let mut i = 0;
        let buf_ptr = id_buf_phys as Ptr<u8>;
        while i < 40 {
            let c = buf_ptr.offset(24 + i).read();
            if c != 0 {
                unsafe { outb(0x3F8, c); }
            }
            i = i + 1;
        }
        serial.print("\n");
        
        // --- PHASE 2: IO QUEUES AND BLOCK R/W ---
        serial.print("Creating NVMe I/O Queues...\n");
        let iosq_phys: u64 = 0x2004000;
        let iocq_phys: u64 = 0x2005000;
        nvme.zero_memory(iosq_phys as Ptr<u8>, 4096);
        nvme.zero_memory(iocq_phys as Ptr<u8>, 4096);
        
        nvme.init_io_queues(ctrl_ptr, iosq_phys, iocq_phys);
        
        let write_buf_phys: u64 = 0x2006000;
        let read_buf_phys: u64 = 0x2007000;
        
        // Fill write_buf with a pattern
        let write_ptr = write_buf_phys as Ptr<u32>;
        write_ptr.offset(0).write(0xDEADBEEF);
        write_ptr.offset(1).write(0xCAFEBABE);
        write_ptr.offset(2).write(0x8BADF00D);
        write_ptr.offset(3).write(0x0DEFACED);
        
        serial.print("Writing Block to LBA 0...\n");
        nvme.write_block(ctrl_ptr, 0, write_buf_phys, 1);
        let write_status = nvme.poll_io_cq(ctrl_ptr);
        serial.print("Write Command Complete. Status: ");
        serial.print_hex(write_status as u64);
        serial.print("\n");
        
        serial.print("Reading Block from LBA 0...\n");
        nvme.read_block(ctrl_ptr, 0, read_buf_phys, 1);
        let read_status = nvme.poll_io_cq(ctrl_ptr);
        serial.print("Read Command Complete. Status: ");
        serial.print_hex(read_status as u64);
        serial.print("\n");
        
        // Verify
        let read_ptr = read_buf_phys as Ptr<u32>;
        if read_ptr.offset(0).read() == 0xDEADBEEF {
            if read_ptr.offset(1).read() == 0xCAFEBABE {
                serial.print("NVMe Block R/W Verified!\n");
            } else {
                serial.print("Error: Block read mismatch at offset 1.\n");
            }
        } else {
            serial.print("Error: Block read mismatch at offset 0.\n");
        }


    } else {
        serial.print("NVMe Controller NOT found.\n");
    }

    serial.print("Test complete. Exiting QEMU.\n");
    qemu_exit(0);

    // If exit fails, halt
    while true { }
}
