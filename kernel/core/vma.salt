// =============================================================================
// kernel/core/vma.salt
// Virtual Memory Area Tracker — Slab-Cached Process Memory Metadata
// =============================================================================
//
// A VMA represents a contiguous region of dynamically mapped virtual memory
// belonging to a Ring 3 process. VMA objects are allocated from the slab cache
// (32 bytes each, 128 per 4KB page) to avoid wasting full PMM pages on
// small metadata structures.
//
// This module is strictly a FACTORY for VMA objects. Linking VMAs into a
// process's memory map is the responsibility of syscall.salt (sys_mmap)
// or exec_user.salt (process teardown).
// =============================================================================

package kernel.core.vma

import kernel.mem.slab_cache
import kernel.drivers.serial

// =============================================================================
// VMA Struct — 32 bytes (4 x u64)
// =============================================================================
pub struct Vma {
    pub vaddr_start: u64,   // Start of the virtual memory region
    pub vaddr_end: u64,     // End of the virtual memory region (exclusive)
    pub flags: u64,         // Permission flags (PTE_PRESENT | PTE_WRITE | PTE_USER)
    pub next: u64,          // Virtual address of the next Vma in the linked list (0 = end)
}

// =============================================================================
// Globals
// =============================================================================

// Opaque cache handle returned by slab_cache.create_cache()
global VMA_CACHE_ID: u64 = 0;

// =============================================================================
// init — Create the 32-byte VMA slab cache.
// Called once during kernel boot, after slab_cache.init().
// =============================================================================
pub fn init() {
    // A Vma struct is exactly 32 bytes (4 x 8-byte fields).
    // The slab cache adds 8 bytes for the Redzone, making each slot 40 bytes.
    // This packs 102 VMA objects per 4KB PMM page (4096 / 40 = 102).
    VMA_CACHE_ID = slab_cache.create_cache(32);
    serial.print("[vma] VMA cache initialized (32-byte objects)\n");
}

// =============================================================================
// alloc — Allocate a new VMA and initialize its fields.
// Returns the virtual address of the Vma object, or 0 on OOM.
// =============================================================================
pub fn alloc(start: u64, end: u64, flags: u64) -> u64 {
    let ptr = slab_cache.alloc(VMA_CACHE_ID);

    // Strict OOM Propagation
    if ptr == 0 {
        serial.print("[vma] FATAL: OOM allocating VMA\n");
        return 0;
    }

    // Cast to mutable Vma reference and populate fields
    let vma = ptr as &mut Vma;
    vma.vaddr_start = start;
    vma.vaddr_end = end;
    vma.flags = flags;
    vma.next = 0;  // Always initialize the next pointer to null

    return ptr;
}

// =============================================================================
// free — Return a VMA object to the slab cache.
// The slab cache performs Redzone validation internally.
// =============================================================================
pub fn free(ptr: u64) {
    if ptr == 0 { return; }
    slab_cache.free(VMA_CACHE_ID, ptr);
}

// @no_mangle ABI Wrappers
@no_mangle
pub fn vma_init() { init(); }
@no_mangle
pub fn vma_alloc(start: u64, end: u64, flags: u64) -> u64 { return alloc(start, end, flags); }

