// =============================================================================
// kernel/core/ring3_test.salt
// Ring 3 TDD Test Suite — IRETQ Frame Verification
// =============================================================================
//
// TDD Gate 1: Verify user_stack_init builds the exact 5-word IRETQ frame
//   that x86_64 hardware expects for Ring 3 transitions.
//
// Architecture: The IRETQ frame and GPR initialization are pure assembly
//   (user_stack_init in preempt_stub.S). This Salt test declares them as
//   extern fns and uses read_u64 (also assembly) to verify the frame.
//   No raw pointer casts. No volatile wrappers. The verifier sees clean
//   function boundaries.
// =============================================================================

package kernel.core.ring3_test

import kernel.drivers.serial
import kernel.core.memory

// =============================================================================
// Constants — must match gdt.salt and preempt_stub.S
// =============================================================================
const IRETQ_SS: u64      = 0x23;    // User Data segment | RPL 3
const IRETQ_CS: u64      = 0x2B;    // User Code 64 segment | RPL 3
const IRETQ_RFLAGS: u64  = 0x202;   // IF=1 (interrupts enabled)
const USER_STACK_TOP: u64 = 0x7FFFFFFFE000;

// =============================================================================
// Hardware ABI Boundary — assembly extern functions (preempt_stub.S)
// =============================================================================
extern fn user_stack_init(stack_top: u64, entry_addr: u64, user_rsp: u64) -> u64;
extern fn read_u64(addr: u64) -> u64;

// PMM — page allocation for test stack
extern fn pmm_alloc() -> u64;
extern fn pmm_free(addr: u64);

// =============================================================================
// TDD Gate 1 — Verify IRETQ Frame Construction
// =============================================================================
// Allocates a page, calls user_stack_init (pure assembly), then reads back
// each word with read_u64 (pure assembly) and compares against expected values.
// =============================================================================
@no_mangle
pub fn test_ring3_iretq_frame() {
    serial.print("TEST:ring3:iretq_frame:BEGIN\n");

    // Allocate a test page via PMM
    let phys = pmm_alloc();
    if phys == 0 {
        serial.print("TEST:ring3:iretq_alloc:FAIL OOM\n");
        return;
    }
    let virt = memory.phys_to_virt(memory.PhysAddr { val: phys }).val;
    let stack_top = virt + 4096;

    // Test values
    let test_entry: u64 = 0x400000;
    let test_user_rsp: u64 = USER_STACK_TOP;

    // Build the IRETQ frame via the assembly ABI boundary
    let ctx_ptr = user_stack_init(stack_top, test_entry, test_user_rsp);

    // --- Verify ctx_ptr is sane (should be stack_top - 160, aligned) ---
    if ctx_ptr == 0 {
        serial.print("TEST:ring3:iretq_ctx:FAIL null\n");
        pmm_free(phys);
        return;
    }
    serial.print("TEST:ring3:iretq_ctx:PASS ctx_ptr=0x");
    serial.print_hex(ctx_ptr);
    serial.print("\n");

    // --- Read IRETQ frame words via read_u64 (assembly helper) ---
    // The frame is at the TOP of the stack (after 15 GPRs).
    // Frame layout from preempt_stub.S user_stack_init:
    //   ctx_ptr + 120 = RIP   (15 GPRs * 8 = 120 offset)
    //   ctx_ptr + 128 = CS
    //   ctx_ptr + 136 = RFLAGS
    //   ctx_ptr + 144 = RSP
    //   ctx_ptr + 152 = SS
    let rip    = read_u64(ctx_ptr + 120);
    let cs     = read_u64(ctx_ptr + 128);
    let rflags = read_u64(ctx_ptr + 136);
    let rsp    = read_u64(ctx_ptr + 144);
    let ss     = read_u64(ctx_ptr + 152);

    // --- SS ---
    let mut pass_count: u64 = 0;
    if ss == IRETQ_SS {
        serial.print("TEST:ring3:iretq_ss:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:iretq_ss:FAIL expected=0x23 got=0x");
        serial.print_hex(ss);
        serial.print("\n");
    }

    // --- RSP ---
    if rsp == test_user_rsp {
        serial.print("TEST:ring3:iretq_rsp:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:iretq_rsp:FAIL expected=0x");
        serial.print_hex(test_user_rsp);
        serial.print(" got=0x");
        serial.print_hex(rsp);
        serial.print("\n");
    }

    // --- RFLAGS ---
    if rflags == IRETQ_RFLAGS {
        serial.print("TEST:ring3:iretq_rflags:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:iretq_rflags:FAIL expected=0x202 got=0x");
        serial.print_hex(rflags);
        serial.print("\n");
    }

    // --- CS ---
    if cs == IRETQ_CS {
        serial.print("TEST:ring3:iretq_cs:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:iretq_cs:FAIL expected=0x2B got=0x");
        serial.print_hex(cs);
        serial.print("\n");
    }

    // --- RIP ---
    if rip == test_entry {
        serial.print("TEST:ring3:iretq_rip:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:iretq_rip:FAIL expected=0x");
        serial.print_hex(test_entry);
        serial.print(" got=0x");
        serial.print_hex(rip);
        serial.print("\n");
    }

    // --- GPR[0] should be zero ---
    let gpr0 = read_u64(ctx_ptr);
    if gpr0 == 0 {
        serial.print("TEST:ring3:iretq_gpr0:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:iretq_gpr0:FAIL got=0x");
        serial.print_hex(gpr0);
        serial.print("\n");
    }

    // Summary
    serial.print("TEST:ring3:iretq_frame:");
    if pass_count == 6 {
        serial.print("ALL_PASS");
    } else {
        serial.print("PARTIAL ");
        serial.print_u64(pass_count);
        serial.print("/6");
    }
    serial.print("\n");

    // Free the test page
    pmm_free(phys);
}

// =============================================================================
// TDD Gate 3 — End-to-End Ring 3 → SYSCALL → Exit Code Verification
// =============================================================================
// The Final Test. Exercises the complete Ring 3 lifecycle:
//   1. Allocate Ring 3 stack (PMM page)
//   2. Drop to Ring 3 via IRETQ (drop_to_ring3_and_bench)
//   3. Ring 3 payload executes SYSCALL(0xDEAD, 42)
//   4. syscall_entry_fast catches sentinel, stores exit_code=42
//   5. bench_ring0_restore escapes back to Ring 0
//   6. Test reads ring3_test_exit_code and asserts == 42
//
// Architecture boundary:
//   drop_to_ring3_and_bench → IRETQ → ring3_test_exit_payload
//   ring3_test_exit_payload → SYSCALL → syscall_entry_fast (.Ltest_exit)
//   .Ltest_exit → bench_ring0_restore → returns here
// =============================================================================
extern fn drop_to_ring3_and_bench(ring3_func: u64, ring3_stack: u64);
extern fn ring3_test_exit_payload();
extern fn read_ring3_test_exit_code() -> u64;
extern fn fn_addr(f: fn()) -> u64;

@no_mangle
pub fn test_ring3_e2e() {
    serial.print("TEST:ring3:e2e:BEGIN\n");

    let mut pass_count: u64 = 0;

    // 1. Allocate a Ring 3 user stack page
    let stack_phys = pmm_alloc();
    if stack_phys == 0 {
        serial.print("TEST:ring3:e2e_alloc:FAIL OOM\n");
        return;
    }
    let stack_virt = memory.phys_to_virt(memory.PhysAddr { val: stack_phys }).val;
    let ring3_stack_top = stack_virt + 4096;

    // 2. Get the Ring 3 payload function address
    let payload_addr = fn_addr(ring3_test_exit_payload);

    serial.print("TEST:ring3:e2e:payload=0x");
    serial.print_hex(payload_addr);
    serial.print(" stack=0x");
    serial.print_hex(ring3_stack_top);
    serial.print("\n");

    // 3. Drop to Ring 3 — this appears to "return normally" after the
    //    payload executes SYSCALL(0xDEAD, 42) and bench_ring0_restore
    //    brings us back to Ring 0.
    drop_to_ring3_and_bench(payload_addr, ring3_stack_top);

    // 4. We're back in Ring 0. Read the exit code captured by the sentinel.
    let exit_code = read_ring3_test_exit_code();

    serial.print("TEST:ring3:e2e:exit_code=");
    serial.print_u64(exit_code);
    serial.print("\n");

    // 5. Verify exit_code == 42
    if exit_code == 42 {
        serial.print("TEST:ring3:e2e_exit_code:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:e2e_exit_code:FAIL expected=42 got=");
        serial.print_u64(exit_code);
        serial.print("\n");
    }

    // 6. Verify we actually transitioned to Ring 3 (the payload ran)
    //    If exit_code != sentinel default (0xFF..F), the round-trip happened.
    if exit_code != 0 {
        serial.print("TEST:ring3:e2e_round_trip:PASS\n");
        pass_count = pass_count + 1;
    } else {
        serial.print("TEST:ring3:e2e_round_trip:FAIL (exit_code=0, payload may not have run)\n");
    }

    // Summary
    serial.print("TEST:ring3:e2e:");
    if pass_count == 2 {
        serial.print("ALL_PASS");
    } else {
        serial.print("PARTIAL ");
        serial.print_u64(pass_count);
        serial.print("/2");
    }
    serial.print("\n");

    // Free the stack page
    pmm_free(stack_phys);
}

extern fn ring3_swapgs_test_payload();
extern fn apic_init_nmi_timer(count: u32);
extern fn read_nmi_diag_count() -> u64;
extern fn clear_nmi_diag_count();

// =============================================================================
// test_swapgs_ring3 — Validates NMI SWAPGS Correctness from Ring 3
// =============================================================================
// Proves the `nmi_handler.S` paranoid SWAPGS logic correctly detects a Ring 3
// origin, issues a `swapgs`, and successfully returns via `iretq`. This tests a
// genuine asynchronous hardware NMI delivered via the APIC timer.
// =============================================================================
@no_mangle
pub fn test_swapgs_ring3() {
    serial.print("TEST:ring3:swapgs_nmi:BEGIN\n");

    // 1. Setup Ring 3 stack
    let stack_phys = pmm_alloc();
    if stack_phys == 0 {
        serial.print("TEST:ring3:swapgs_alloc:FAIL OOM\n");
        return;
    }
    let stack_virt = memory.phys_to_virt(memory.PhysAddr { val: stack_phys }).val;
    let ring3_stack_top = stack_virt + 4096;

    // 2. Clear NMI diagnostic counter and arm APIC Timer in NMI mode
    clear_nmi_diag_count();
    // 1M APIC ticks shouldn't take long, but should be long enough for the spin loop to start 
    apic_init_nmi_timer(100000); 

    // 3. Drop to Ring 3. The payload spins waiting for the NMI, then escapes via sentinel.
    let payload_addr = fn_addr(ring3_swapgs_test_payload);
    drop_to_ring3_and_bench(payload_addr, ring3_stack_top);

    // 4. Test completed, we are back in Ring 0.
    let exit_code = read_ring3_test_exit_code();
    let nmi_count = read_nmi_diag_count();

    serial.print("TEST:ring3:swapgs:exit_code=");
    serial.print_u64(exit_code);
    serial.print(" nmi_count=");
    serial.print_u64(nmi_count);
    serial.print("\n");

    if exit_code == 43 && nmi_count > 0 {
        serial.print("TEST:ring3:swapgs:PASS (Hardware NMI swapgs worked)\n");
    } else {
        serial.print("TEST:ring3:swapgs:FAIL (either exit code wrong or NMI never fired)\n");
    }

    // Free the stack page
    pmm_free(stack_phys);
}
