// =============================================================================
// kernel/core/dispatcher.salt
// Kernel Event Dispatcher — Immortal Ring 0 Thread (Task 0)
// =============================================================================
//
// The dispatcher is a dedicated Ring 0 kernel thread that drains the
// PulseEvent ring buffer and routes events to subsystems. It runs as
// Process slot 0 with its own kernel stack and IF=1.
//
// Architecture:
//   ISRs (IF=0) → pulse.push()      → ring buffer
//   Task 0 (IF=1) → pulse.pop()     → event handler
//   scheduler → priority Task 0     → when events pending
//
// This is lock-free by design: ISRs are the sole producer (IF=0),
// Task 0 is the sole consumer (IF=1). No CAS, no spinlocks.
// =============================================================================

package kernel.core.dispatcher

import kernel.core.pulse
import kernel.drivers.serial

extern fn idle_halt();
extern fn schedule_next();

// =============================================================================
// kernel_event_loop — Immortal event drain loop (Task 0 entry point)
// =============================================================================
// This function never returns. It runs as a Ring 0 kernel thread with IF=1.
// When the queue is empty, it halts the CPU until the next hardware interrupt.
// The preemptive scheduler will context-switch to user processes as needed.
// =============================================================================
@no_mangle
pub fn kernel_event_loop() {
    serial.print("[Task 0] Dispatcher thread started\n");

    let mut data: u64 = 0;
    let mut timestamp: u64 = 0;
    let mut loop_count: u64 = 0;

    loop {
        loop_count = loop_count + 1;
        if (loop_count % 1000000) == 0 {
            serial.print("[Task 0] Heartbeat #");
            serial.print_u64(loop_count / 1000000);
            serial.print(" ... yielding back to Ring 3\n");
        }

        // Drain the queue completely
        let mut event_type = pulse.pop(&data, &timestamp);

        while event_type != 0 {
            // Route by event type
            if event_type == pulse.PULSE_TIMER {
                handle_timer(data, timestamp);
            } else if event_type == pulse.PULSE_KEYBOARD {
                handle_keyboard(data, timestamp);
            } else if event_type == pulse.PULSE_SERIAL {
                handle_serial(data, timestamp);
            }

            event_type = pulse.pop(&data, &timestamp);
        }

        // Queue is empty — yield the CPU to Ring 3 user processes.
        // Without a timer interrupt (bench suite bypassed), idle_halt()
        // would sleep forever. sched_yield() cooperatively hands the
        // baton to the MoE coroutine so its yield-poll loop can spin.
        schedule_next();

        // When rescheduled, we resume right here and drain again.
    }
}

// =============================================================================
// Event Handlers
// =============================================================================

fn handle_timer(data: u64, timestamp: u64) {
    // Timer tick — future: deadline tracking, watchdog timers
    return;
}

fn handle_keyboard(scancode: u64, timestamp: u64) {
    // Future: route to input subsystem
    serial.print("[pulse] KEY: 0x");
    serial.print_u64(scancode);
    serial.print("\n");
}

fn handle_serial(data: u64, timestamp: u64) {
    // Future: route to console/UART subsystem
    return;
}
