@no_mangle
pub fn process_get_kernel_stack_top(slot: u64) -> u64 { return get_kernel_stack_top(slot); }

@no_mangle
pub fn process_alloc_pid() -> u64 { return alloc_pid(); }

@no_mangle
pub fn process_init() { }

@no_mangle
pub fn process_current() -> u64 { return current(); }
@no_mangle
pub fn process_get_state(slot: u64) -> u64 { return get_state(slot); }
@no_mangle
pub fn process_get_count() -> u64 { return get_count(); }
@no_mangle
pub fn process_dec_count() { }
@no_mangle
