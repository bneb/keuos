@no_mangle
pub fn process_get_brk_base(slot: u64) -> u64 { return get_brk_base(slot); }
@no_mangle
pub fn process_get_brk_current(slot: u64) -> u64 { return get_brk_current(slot); }
@no_mangle
pub fn process_get_mmap_base(slot: u64) -> u64 { return get_mmap_base(slot); }
@no_mangle
pub fn process_set_brk_current(slot: u64, val: u64) { set_brk_current(slot, val); }
@no_mangle
pub fn process_set_fd_table(slot: u64, phys: u64) { set_fd_table(slot, phys); }
@no_mangle
pub fn process_set_mmap_base(slot: u64, val: u64) { set_mmap_base(slot, val); }
@no_mangle
pub fn process_get_parent_pid(slot: u64) -> u64 { return get_parent_pid(slot); }
@no_mangle
pub fn process_get_pid(slot: u64) -> u64 { return get_pid(slot); }
@no_mangle
pub fn process_get_vma_list_head(slot: u64) -> u64 { return get_vma_list_head(slot); }

// =============================================================================
// IPC Fast-Path Accessors
// =============================================================================
// SMP Safety: Write msg0/1/2 BEFORE sender. The consumer checks ipc_sender
// to determine if a message is present. On x86-64 TSO, stores are ordered,
// so when the consumer sees sender != 0, msg0/1/2 are guaranteed visible.
// On non-TSO architectures, replace the sender write with atomic_store_release.
pub fn set_ipc_msg(slot: u64, sender: u64, msg0: u64, msg1: u64, msg2: u64) {
    PROC_TABLE[slot].ipc_msg0 = msg0;
    PROC_TABLE[slot].ipc_msg1 = msg1;
    PROC_TABLE[slot].ipc_msg2 = msg2;
    // Store-release: sender is the "published" flag. Must be written last.
    PROC_TABLE[slot].ipc_sender = sender;
}

pub fn get_ipc_sender(slot: u64) -> u64 { return PROC_TABLE[slot].ipc_sender; }
pub fn get_ipc_sender_addr(slot: u64) -> u64 { return (&PROC_TABLE[slot].ipc_sender) as u64; }
pub fn get_ipc_msg0(slot: u64) -> u64 { return PROC_TABLE[slot].ipc_msg0; }
pub fn get_ipc_msg1(slot: u64) -> u64 { return PROC_TABLE[slot].ipc_msg1; }
pub fn get_ipc_msg2(slot: u64) -> u64 { return PROC_TABLE[slot].ipc_msg2; }

// =============================================================================
// Ring-Buffer ABI Accessors
// =============================================================================
pub fn get_ring_active(slot: u64) -> u64 { return PROC_TABLE[slot].ring_active; }
pub fn set_ring_active(slot: u64, val: u64) { PROC_TABLE[slot].ring_active = val; }
pub fn get_ring_sq_kern(slot: u64) -> u64 { return PROC_TABLE[slot].ring_sq_kern; }
pub fn set_ring_sq_kern(slot: u64, val: u64) { PROC_TABLE[slot].ring_sq_kern = val; }
pub fn get_ring_cq_kern(slot: u64) -> u64 { return PROC_TABLE[slot].ring_cq_kern; }
pub fn set_ring_cq_kern(slot: u64, val: u64) { PROC_TABLE[slot].ring_cq_kern = val; }
pub fn get_ring_sq_phys(slot: u64) -> u64 { return PROC_TABLE[slot].ring_sq_phys; }
pub fn set_ring_sq_phys(slot: u64, val: u64) { PROC_TABLE[slot].ring_sq_phys = val; }
pub fn get_ring_cq_phys(slot: u64) -> u64 { return PROC_TABLE[slot].ring_cq_phys; }
pub fn set_ring_cq_phys(slot: u64, val: u64) { PROC_TABLE[slot].ring_cq_phys = val; }
pub fn get_ring_capacity(slot: u64) -> u64 { return PROC_TABLE[slot].ring_capacity; }
pub fn set_ring_capacity(slot: u64, cap: u64) {
    if slot >= MAX_PROCS { return; }
    PROC_TABLE[slot as i64].ring_capacity = cap;
}

pub fn get_fd_table(slot: u64) -> u64 {
    if slot >= MAX_PROCS { return 0; }
    return PROC_TABLE[slot as i64].fd_table;
}

pub fn set_fd_table(slot: u64, table: u64) {
    if slot >= MAX_PROCS { return; }
    PROC_TABLE[slot as i64].fd_table = table;
}

@no_mangle
pub fn process_set_ecs_entity(slot: u64, entity_val: u64) { set_ecs_entity(slot, entity_val); }

@no_mangle
pub fn process_get_ecs_entity(slot: u64) -> u64 { return get_ecs_entity(slot); }

pub fn get_ecs_entity(slot: u64) -> u64 { return PROC_TABLE[slot].ecs_entity_val; }
pub fn set_ecs_entity(slot: u64, val: u64) { if slot >= MAX_PROCS { return; } PROC_TABLE[slot].ecs_entity_val = val; }

@no_mangle
pub fn process_set_ipc_msg(slot: u64, sender: u64, msg0: u64, msg1: u64, msg2: u64) {
    set_ipc_msg(slot, sender, msg0, msg1, msg2);
}

@no_mangle
pub fn process_get_ipc_sender(slot: u64) -> u64 { return get_ipc_sender(slot); }
@no_mangle
pub fn process_get_ipc_msg0(slot: u64) -> u64 { return get_ipc_msg0(slot); }
@no_mangle
pub fn process_get_ipc_msg1(slot: u64) -> u64 { return get_ipc_msg1(slot); }
@no_mangle
pub fn process_get_ipc_msg2(slot: u64) -> u64 { return get_ipc_msg2(slot); }
@no_mangle
pub fn process_get_state_addr(slot: u64) -> u64 { return get_state_addr(slot); }
@no_mangle
pub fn process_get_rsp_addr(slot: u64) -> u64 { return get_rsp_addr(slot); }
@no_mangle
pub fn process_get_ipc_sender_addr(slot: u64) -> u64 { return get_ipc_sender_addr(slot); }
@no_mangle
pub fn process_set_parent_pid(slot: u64, ppid: u64) { set_parent_pid(slot, ppid); }
@no_mangle
pub fn process_set_vma_list_head(slot: u64, val: u64) { set_vma_list_head(slot, val); }
