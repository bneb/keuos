// =============================================================================
// kernel/core/pulse.salt
// PulseEvent Ring Buffer — Lock-Free SPSC Hardware Event Queue
// =============================================================================
//
// Single-Producer Single-Consumer ring buffer for hardware → kernel event
// delivery. ISRs are the sole producer (interrupt context); the kernel
// dispatcher is the sole consumer (normal context).
//
// Design constraints for ISR safety:
//   - O(1) push with zero allocation (fixed .bss buffer)
//   - No locks, no CAS — SPSC guarantees correctness
//   - ISR writes HEAD, dispatcher reads HEAD and writes TAIL
//
// Ring buffer layout:
//   RING[0..255] — 256 PulseEvent slots (24 bytes each = 6KB total)
//   HEAD         — next write position (ISR-owned)
//   TAIL         — next read position (dispatcher-owned)
//   Buffer full when (HEAD + 1) % SIZE == TAIL (one slot wasted)
// =============================================================================

package kernel.core.pulse

import kernel.drivers.serial

// =============================================================================
// Event Types
// =============================================================================
pub const PULSE_TIMER: u64    = 1;
pub const PULSE_KEYBOARD: u64 = 2;
pub const PULSE_SERIAL: u64   = 3;
pub const PULSE_VIRTIO: u64   = 4;

// =============================================================================
// PulseEvent — 24 bytes (3 x u64)
// =============================================================================
pub struct PulseEvent {
    pub event_type: u64,    // PULSE_TIMER, PULSE_KEYBOARD, etc.
    pub data: u64,          // Event-specific payload (scancode, byte count, etc.)
    pub timestamp: u64,     // Monotonic tick counter at enqueue time
}

// =============================================================================
// Ring Buffer — Fixed 256 slots in .bss
// =============================================================================
const RING_SIZE: u64 = 256;
const EVENT_STRIDE: u64 = 24;  // sizeof(PulseEvent) = 3 * 8 bytes

// We store PulseEvents as flat u64 triples in a contiguous array.
// Each event occupies 3 consecutive u64 slots.
global RING: [u64; 768] = [0 as u64; 768];  // 256 events * 3 u64s

global HEAD: u64 = 0;  // Next write position (ISR-owned)
global TAIL: u64 = 0;  // Next read position (dispatcher-owned)

// Monotonic tick counter — incremented on every timer event
global TICK_COUNTER: u64 = 0;

// Diagnostic: total events dropped due to full buffer
global DROP_COUNT: u64 = 0;

extern fn ecs_push_hardware_interrupt(irq: u8);

// =============================================================================
// push — Enqueue a PulseEvent from ISR context. O(1), no alloc, no locks.
// Returns 1 on success, 0 if the ring is full (event dropped).
// =============================================================================
pub fn push(event_type: u64, data: u64) -> u64 {
    let next_head = (HEAD + 1) % RING_SIZE;
    if next_head == TAIL {
        DROP_COUNT = DROP_COUNT + 1;
        return 0; // Ring full
    }

    let base = HEAD * 3;
    RING[base] = event_type;
    RING[base + 1] = data;
    RING[base + 2] = TICK_COUNTER;

    HEAD = next_head;
    
    // Also push to the DBOS ECS hardware events pipeline
    ecs_push_hardware_interrupt(event_type as u8);
    
    return 1;
}

// =============================================================================
// pop — Dequeue a PulseEvent from dispatcher context.
// Returns the event_type (0 if empty). Writes data and timestamp via out-ptrs.
// =============================================================================
pub fn pop(out_data: &mut u64, out_timestamp: &mut u64) -> u64 {
    // Ring empty
    if HEAD == TAIL {
        return 0;
    }

    // Read the event from TAIL position
    let base = TAIL * 3;
    let event_type = RING[base];
    *out_data = RING[base + 1];
    *out_timestamp = RING[base + 2];

    // Advance TAIL
    TAIL = (TAIL + 1) % RING_SIZE;
    return event_type;
}

// =============================================================================
// is_empty — Check if the ring buffer has pending events
// =============================================================================
pub fn is_empty() -> bool {
    return HEAD == TAIL;
}

// =============================================================================
// tick — Increment the monotonic tick counter (called from timer ISR)
// =============================================================================
pub fn tick() {
    TICK_COUNTER = TICK_COUNTER + 1;
}

// =============================================================================
// get_tick — Read the current tick counter
// =============================================================================
pub fn get_tick() -> u64 {
    return TICK_COUNTER;
}

// =============================================================================
// get_drop_count — Read total events dropped (diagnostic)
// =============================================================================
pub fn get_drop_count() -> u64 {
    return DROP_COUNT;
}

@no_mangle
pub fn pulse_is_empty() -> bool { return is_empty(); }
